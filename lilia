def render_document(title: str, intro: str, sections: list[tuple[str, str]]) -> str:
    parts = [f"# {title}", "", render_applied_header()]
    if intro:
        parts.extend(["", intro.strip()])
    for heading, body in sections:
        parts.extend(["", f"## {heading}", "", body.strip()])
    return "\n".join(parts) + "\n"


