def find_codex_rollouts_for_repo() -> list[tuple[Path, Path]]:
    """Find codex rollout JSONL files whose session cwd matches this repo.

    Returns (source_path, relative_path) tuples. relative_path is relative to
    ~/.codex/sessions/ so archive-codex-logs can mirror Codex's layout.
    """
    codex_sessions = Path.home() / ".codex" / "sessions"
    if not codex_sessions.is_dir():
        return []

    matches: list[tuple[Path, Path]] = []
    repo_root_resolved = ROOT.resolve()

    for jsonl in sorted(codex_sessions.rglob("rollout-*.jsonl")):
        try:
            with jsonl.open("r", encoding="utf-8") as handle:
                first_line = handle.readline()
            if not first_line.strip():
                continue
            meta = json.loads(first_line)
        except (OSError, json.JSONDecodeError):
            continue

        if meta.get("type") != "session_meta":
            continue

        payload = meta.get("payload")
        if not isinstance(payload, dict):
            continue
        cwd_str = payload.get("cwd")
        if not cwd_str:
            continue

        try:
            cwd_resolved = Path(cwd_str).expanduser().resolve()
        except (OSError, RuntimeError):
            continue

        if cwd_resolved != repo_root_resolved:
            continue

        try:
            relative = jsonl.relative_to(codex_sessions)
        except ValueError:
            continue
        matches.append((jsonl, relative))

    return matches


def command_archive_codex_logs(args: list[str]) -> None:
    if args:
        die("archive-codex-logs does not accept arguments")

    codex_sessions_dir = Path.home() / ".codex" / "sessions"
    archive_root = ROOT / "logs" / "codex_rollouts"
    matches = find_codex_rollouts_for_repo()
    if not matches:
        if not codex_sessions_dir.is_dir():
            print(f"no codex sessions directory found at {codex_sessions_dir}")
        else:
            print("no codex rollouts found whose cwd matches this LILIA repo.")
        print(f"archive: {archive_root.relative_to(ROOT)}")
        return

    copied: list[str] = []
    skipped: list[str] = []

    for source, rel_path in matches:
        dest = archive_root / rel_path
        name = str(rel_path)
        if dest.exists():
            skipped.append(name)
            continue
        try:
            dest.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(source, dest)
        except OSError as exc:
            print(f"copy failed: {name}: {exc}", flush=True)
            continue
        copied.append(name)

    print(f"archive: {archive_root.relative_to(ROOT)}")
    print(f"copied: {len(copied)}")
    for name in copied:
        print(f"  {name}")
    if skipped:
        print(f"skipped (already archived): {len(skipped)}")
        for name in skipped:
            print(f"  {name}")


