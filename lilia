def _ensure_judge_default(args: list[str]) -> list[str]:
    """Add --judge unless --no-judge or --judge already present."""

    if "--no-judge" in args:
        return list(args)
    if "--judge" in args:
        return list(args)
    return list(args) + ["--judge"]


def _ensure_default_flag(args: list[str], flag: str, value: str) -> list[str]:
    """If neither ``flag`` nor ``flag=`` appears in args, append ``flag value``."""

    for arg in args:
        if arg == flag or arg.startswith(f"{flag}="):
            return list(args)
    return list(args) + [flag, value]


