def resolve_lilia_name_layers(
    *,
    profile: str = "",
    answers: Optional[dict[int | str, str]] = None,
    logger: Optional[OperationLogger] = None,
) -> tuple[str, str]:
    profile_name = extract_profile_name(profile) if profile else ""
    if profile_name:
        return profile_name, "layer_a_profile"
    if answers:
        explicit = explicit_name_from_answers(answers)
        if explicit:
            return explicit, "layer_a_explicit_answer"
    inferred = ai_reinfer_name_stub(profile, answers, logger)
    if inferred:
        return inferred, "layer_b_ai_reinfer"
    return PLACEHOLDER_LILIA_NAME, "layer_c_placeholder"


