def choose_engine(requested: str) -> Optional[str]:
    if requested == "auto":
        if shutil.which("codex"):
            return "codex"
        if shutil.which("claude"):
            return "claude"
        return None
    if shutil.which(requested):
        return requested
    return None


def codex_interactive_command(instruction: Optional[str] = None) -> list[str]:
    command = [
        "codex",
        "--cd",
        str(ROOT),
        "--sandbox",
        "workspace-write",
        "--no-alt-screen",
    ]
    if instruction:
        command.append(instruction)
    return command


