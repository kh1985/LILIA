def choose_engine(requested: str) -> Optional[str]:
    if requested == "auto":
        if shutil.which("codex"):
            return "codex"
        if shutil.which("claude"):
            return "claude"
        return None
    if shutil.which(requested):
        return requested
    return None


def codex_interactive_command(instruction: Optional[str] = None) -> list[str]:
    command = [
        "codex",
        "--cd",
        str(ROOT),
        "--sandbox",
        "workspace-write",
        "--no-alt-screen",
    ]
    if instruction:
        command.append(instruction)
    return command


def codex_interactive_instruction(prompt_path: Path, mode: str, session_path: Path) -> str:
    if mode == "new":
        return (
            f"Read {prompt_path} and follow it for LILIA. "
            "Do not start AI Harness or autoplay. "
            "Ask Q1-Q7, generate lilia/main/profile.md, then start the first scene. "
            "Do not stop at first_scene_pending/first_scene_ready. "
            "During normal play after the first scene starts, do not edit story/state files or run git checks after every user turn. "
            "Respond in playable scene text first. Enter save/update mode only when the user explicitly asks to save/update "
            "or when initialization requires file generation. If needed after a normal play turn, run ./lilia scene-tick "
            f"{session_path.name} only as an autosave counter tick; it is not a save. If autosave_required becomes true, "
            "suggest saving but do not run apply-turn unless the user asks. Do not expose internal save reasoning to the player."
        )

    data = read_session_json(session_path)
    if data.get("current_phase") in {"first_scene_pending", "first_scene_ready"}:
        phase = data.get("current_phase")
        return (
            f"Read {prompt_path} and continue LILIA from {phase}. "
            "Start the first scene now. Do not run checks. "
            "Do not edit files unless the prompt explicitly requires it. "
            "Output the playable scene text first. "
            "After the first scene starts, do not edit story/state files or run git checks after every user turn. "
            "Enter save/update mode only when the user explicitly asks to save/update. "
            "If needed after a normal play turn, run ./lilia scene-tick "
            f"{session_path.name} only as an autosave counter tick; it is not a save. If autosave_required becomes true, "
            "suggest saving but do not run apply-turn unless the user asks. Do not expose internal save reasoning to the player."
        )

    return (
        f"Read {prompt_path} and continue LILIA. "
        "Do not start AI Harness or autoplay. "
        "During normal play, do not edit story/state files or run git checks after every user turn. "
        "Respond in playable scene text first. "
        "Enter save/update mode only when the user explicitly asks to save/update or when initialization requires file generation. "
        "If needed after a normal play turn, run ./lilia scene-tick "
        f"{session_path.name} only as an autosave counter tick; it is not a save. If autosave_required becomes true, "
        "suggest saving but do not run apply-turn unless the user asks. Do not expose internal save reasoning to the player."
    )


def print_codex_interactive_steps(session_path: Path, prompt_path: Path, mode: str) -> None:
    instruction = codex_interactive_instruction(prompt_path, mode, session_path)
    command = shlex.join(codex_interactive_command(instruction))
    print(f"session: {session_path.relative_to(ROOT)}", flush=True)
    print(f"mode: codex interactive {mode}", flush=True)
    print(f"prompt bundle: {prompt_path}", flush=True)
    print("note: --run uses one-shot 'codex exec'; this flow opens Codex interactive play.", flush=True)
    print("launching Codex interactive with initial instruction:", flush=True)
    print(f"  {instruction}", flush=True)
    print("command:", flush=True)
    print(f"  {command}", flush=True)


def print_codex_interactive_fallback(instruction: str) -> None:
    print("fallback: open Codex interactive manually, then paste:", flush=True)
    print(f"  {instruction}", flush=True)


def maybe_launch_codex_interactive(prompt_path: Path, mode: str, session_path: Path) -> None:
    instruction = codex_interactive_instruction(prompt_path, mode, session_path)
    if not shutil.which("codex"):
        print("codex: not found; install/login to Codex CLI.", flush=True)
        print_codex_interactive_fallback(instruction)
        return
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        print("codex: interactive launch skipped because this shell is not a TTY.", flush=True)
        print_codex_interactive_fallback(instruction)
        return

    print("launching Codex interactive now.", flush=True)
    result = subprocess.run(codex_interactive_command(instruction), cwd=ROOT)
    if result.returncode != 0:
        print(f"codex: interactive launch exited with status {result.returncode}.", flush=True)
        print_codex_interactive_fallback(instruction)


def engine_command(engine: str) -> list[str]:
    if engine == "codex":
        return [
            "codex",
            "exec",
            "--cd",
            str(ROOT),
            "--sandbox",
            "read-only",
            "--color",
            "never",
            "-",
        ]
    if engine == "claude":
        return ["claude", "-p", "--permission-mode", "dontAsk"]
    die(f"unsupported engine: {engine}")


def run_engine(requested_engine: str, session_path: Path, bundle: str) -> None:
    engine = choose_engine(requested_engine)
    if engine is None:
        die(
            "no AI CLI found for --run. Install codex or claude, or use "
            f"'./lilia resume {session_path.name} --prompt-only'."
        )

    print(f"session: {session_path.relative_to(ROOT)}", flush=True)
    print(f"engine: {engine} (requested: {requested_engine})", flush=True)
    print("mode: run", flush=True)
    if engine == "codex":
        print("note: codex engine uses one-shot 'codex exec'; use codex-new/codex-resume for interactive play.", flush=True)
    print("note: prompt bundle is written to a temporary file and removed after the engine exits.", flush=True)

    temp_path: Optional[Path] = None
    try:
        with tempfile.NamedTemporaryFile(
            mode="w",
            encoding="utf-8",
            prefix=f"lilia_{session_path.name}_",
            suffix=".prompt.md",
            delete=False,
        ) as temp_file:
            temp_file.write(bundle)
            temp_path = Path(temp_file.name)

        print(f"prompt bundle: {temp_path}", flush=True)
        with temp_path.open("r", encoding="utf-8") as prompt_file:
            result = subprocess.run(engine_command(engine), stdin=prompt_file, cwd=ROOT)
        if result.returncode != 0:
            die(f"{engine} exited with status {result.returncode}", result.returncode)
    finally:
        if temp_path and temp_path.exists():
            temp_path.unlink()


def command_new(args: list[str]) -> None:
    args, prompt_only, run, engine = parse_run_options(args)
    if len(args) > 1:
        die("new accepts at most one session_name")
    session_path = create_session(args[0] if args else None)
    print(f"created: {session_path.relative_to(ROOT)}", flush=True)
    if run:
        run_engine(engine, session_path, build_new_prompt_bundle(session_path))
    elif prompt_only:
        print_new_prompt_bundle(session_path)
    else:
        print(f"apply answers: ./lilia apply-newgame {session_path.name} answers.md")
        print(f"next: ./lilia resume {session_path.name} --prompt-only")
        print(f"run:  ./lilia resume {session_path.name} --run --engine auto")


def command_resume(args: list[str]) -> None:
    args, prompt_only, run, engine = parse_run_options(args)
    if len(args) > 1:
        die("resume accepts at most one session_name")
    session_path = resolve_session(args[0] if args else None)
    if run:
        run_engine(engine, session_path, build_resume_prompt_bundle(session_path))
    else:
        print(f"session: {session_path.relative_to(ROOT)}", flush=True)
        if prompt_only:
            print_resume_prompt_bundle(session_path)
        else:
            print(f"prompt: ./lilia resume {session_path.name} --prompt-only")
            print(f"run:    ./lilia resume {session_path.name} --run --engine auto")


def command_codex_new(args: list[str]) -> None:
    if len(args) > 1:
        die("codex-new accepts at most one session_name")
    session_path = create_session(args[0] if args else None)
    prompt_path = codex_prompt_path(session_path, "new")
    write_prompt_file(prompt_path, build_codex_new_prompt_bundle(session_path))
    print(f"created: {session_path.relative_to(ROOT)}", flush=True)
    print_codex_interactive_steps(session_path, prompt_path, "new")
    maybe_launch_codex_interactive(prompt_path, "new", session_path)


def command_codex_resume(args: list[str]) -> None:
    if len(args) > 1:
        die("codex-resume accepts at most one session_name")
    session_path = resolve_session(args[0] if args else None)
    prompt_path = codex_prompt_path(session_path, "resume")
    write_prompt_file(prompt_path, build_codex_resume_prompt_bundle(session_path))
    print_codex_interactive_steps(session_path, prompt_path, "resume")
    maybe_launch_codex_interactive(prompt_path, "resume", session_path)


def command_list_sessions() -> None:
    sessions = session_candidates()
    if not sessions:
        print("No sessions found.")
        return

    latest = sessions[0]
    rows = []
    name_width = len("SESSION")
    for path in sessions:
        data = read_session_json(path)
        marker = "*" if path == latest else ""
        name = data.get("session_name") or path.name
        phase = data.get("current_phase") or "-"
        mode = data.get("mode") or "-"
        created = data.get("created_at") or "-"
        name_width = max(name_width, len(str(name)))
        rows.append((marker, str(name), phase, mode, created, path.relative_to(ROOT)))

    print(f"LATEST  {'SESSION':<{name_width}}  PHASE        MODE     CREATED_AT                 PATH")
    for marker, name, phase, mode, created, rel_path in rows:
        print(f"{marker:<7} {name:<{name_width}}  {phase:<12} {mode:<8} {created:<26} {rel_path}")


def command_prompt_only(args: list[str]) -> None:
    if not args:
        command_resume(["--prompt-only"])
        return
    command = args[0]
    rest = args[1:] + ["--prompt-only"]
    if command == "new":
        command_new(rest)
    elif command == "resume":
        command_resume(rest)
    else:
        die("prompt-only accepts 'new' or 'resume'")


def command_apply_newgame(args: list[str]) -> None:
    if len(args) != 2:
        die("apply-newgame requires <session_name> <answers.md>")

    session_path = resolve_session(args[0])
    answers_path = Path(args[1]).expanduser()
    answers = parse_newgame_answers(answers_path)
    documents = render_newgame_documents(answers, session_path.name)
    profile_name = extract_profile_name(documents["lilia/main/profile.md"])
    if not profile_name:
        profile_name = generated_lilia_name(answers, session_path.name)
        documents["lilia/main/profile.md"] = replace_profile_name(
            documents["lilia/main/profile.md"],
            profile_name,
        )

    for rel_path, content in documents.items():
        write_session_file(session_path, rel_path, content)

    data = read_session_json(session_path)
    data["mode"] = data.get("mode") or "new"
    data["current_phase"] = "first_scene_ready"
    data["active_lilia"] = data.get("active_lilia") or "main"
    ensure_lilia_names(data, profile_name)
    initialization = data.setdefault("initialization", {})
    initialization["qa_completed"] = True
    initialization["light_story_reference_pass"] = "minimal_applied"
    initialization["first_scene_status"] = "ready"
    ensure_autosave(data)
    write_session_json(session_path, data)

    print(f"applied: {answers_path}")
    print(f"session: {session_path.relative_to(ROOT)}")
    print("phase: first_scene_ready")
    print("updated:")
    print("  session.json")
    for rel_path in documents:
        print(f"  {rel_path}")


def command_apply_turn(args: list[str]) -> None:
    if len(args) != 2:
        die("apply-turn requires <session_name> <turn_update.md>")

    session_path = resolve_session(args[0])
    update_path = Path(args[1]).expanduser()
    sections = parse_turn_update(update_path)
    if not sections:
        die("turn_update.md has no non-empty supported sections")

    timestamp = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    updated: list[str] = []
    for key, body in sections.items():
        rel_path = TURN_UPDATE_TARGETS[key]
        if key == "hotset":
            write_session_file(session_path, rel_path, render_hotset_update(timestamp, body))
        else:
            append_session_file(session_path, rel_path, render_turn_update_block(timestamp, body))
        updated.append(rel_path)

    data = read_session_json(session_path)
    autosave = ensure_autosave(data)
    autosave["turns_since_save"] = 0
    autosave["autosave_required"] = False
    write_session_json(session_path, data)
    updated.append("session.json")

    print(f"applied: {update_path}")
    print(f"session: {session_path.relative_to(ROOT)}")
    print(f"timestamp: {timestamp}")
    print("updated:")
    for rel_path in updated:
        print(f"  {rel_path}")


def command_scene_tick(args: list[str]) -> None:
    if len(args) != 1:
        die("scene-tick requires <session_name>")

    session_path = resolve_session(args[0])
    data = read_session_json(session_path)
    autosave = ensure_autosave(data)

    try:
        interval = int(autosave.get("interval_turns", AUTOSAVE_DEFAULTS["interval_turns"]))
    except (TypeError, ValueError):
        interval = AUTOSAVE_DEFAULTS["interval_turns"]
    if interval < 1:
        interval = AUTOSAVE_DEFAULTS["interval_turns"]
    autosave["interval_turns"] = interval

    try:
        turns_since_save = int(autosave.get("turns_since_save", 0))
    except (TypeError, ValueError):
        turns_since_save = 0
    if turns_since_save < 0:
        turns_since_save = 0

    turns_since_save += 1
    autosave["turns_since_save"] = turns_since_save

    enabled = bool(autosave.get("enabled", True))
    autosave["enabled"] = enabled
    autosave["autosave_required"] = enabled and turns_since_save >= interval
    write_session_json(session_path, data)

    display_turn = min(turns_since_save, interval)
    print(f"scene tick: {display_turn}/{interval}")
    print(f"autosave_required: {str(autosave['autosave_required']).lower()}")
    if autosave["autosave_required"]:
        print(
            "save recommended: create turn_update.md and run "
            f"./lilia apply-turn {session_path.name} <turn_update.md>"
        )


def main(argv: list[str]) -> None:
    if not argv or argv[0] in {"-h", "--help", "help"}:
        usage()
        return

    command, args = argv[0], argv[1:]
    if command == "new":
        command_new(args)
    elif command == "resume":
        command_resume(args)
    elif command == "codex-new":
        command_codex_new(args)
    elif command == "codex-resume":
        command_codex_resume(args)
    elif command == "list-sessions":
        command_list_sessions()
    elif command == "prompt-only":
        command_prompt_only(args)
    elif command == "apply-newgame":
        command_apply_newgame(args)
    elif command == "apply-turn":
        command_apply_turn(args)
    elif command == "scene-tick":
        command_scene_tick(args)
    else:
        usage()
        die(f"unknown command: {command}")


if __name__ == "__main__":
    main(sys.argv[1:])
