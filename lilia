def parse_ai_playtest_options(
    args: list[str],
) -> tuple[list[str], str, int, str, bool, bool, bool, bool, bool]:
    persona = "normal"
    turns = 10
    engine = "auto"
    verbose = False
    quiet = False
    judge = True
    scene_tick = True
    apply_turn_checkpoint = False
    judge_seen = False
    no_judge_seen = False
    cleaned: list[str] = []
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--persona":
            index += 1
            if index >= len(args):
                die("--persona requires a value")
            persona = args[index]
        elif arg.startswith("--persona="):
            persona = arg.split("=", 1)[1]
        elif arg == "--turns":
            index += 1
            if index >= len(args):
                die("--turns requires a value")
            persona_turns_raw = args[index]
            try:
                turns = int(persona_turns_raw)
            except ValueError:
                die("--turns must be a positive integer")
        elif arg.startswith("--turns="):
            try:
                turns = int(arg.split("=", 1)[1])
            except ValueError:
                die("--turns must be a positive integer")
        elif arg == "--engine":
            index += 1
            if index >= len(args):
                die("--engine requires codex, claude, or auto")
            engine = args[index]
        elif arg.startswith("--engine="):
            engine = arg.split("=", 1)[1]
        elif arg == "--verbose":
            verbose = True
        elif arg == "--quiet":
            quiet = True
        elif arg == "--judge":
            judge_seen = True
            judge = True
        elif arg == "--no-judge":
            no_judge_seen = True
            judge = False
        elif arg == "--no-scene-tick":
            scene_tick = False
        elif arg in {"--apply-turn-checkpoint", "--checkpoint-dry-run"}:
            apply_turn_checkpoint = True
        else:
            cleaned.append(arg)
        index += 1

    if judge_seen and no_judge_seen:
        die("choose either --judge or --no-judge, not both")
    if persona not in AI_PLAYTEST_SUPPORTED_PERSONAS:
        supported = "/".join(sorted(AI_PLAYTEST_SUPPORTED_PERSONAS))
        die(
            f"ai-playtest MVPでは persona={supported} のみサポートしています "
            f"(指定: {persona})"
        )
    if turns < 1:
        die("--turns must be a positive integer")
    if engine not in {"auto", "codex", "claude"}:
        die("--engine must be codex, claude, or auto")
    if verbose and quiet:
        die("choose either --verbose or --quiet, not both")
    return cleaned, persona, turns, engine, verbose, quiet, scene_tick, apply_turn_checkpoint, judge


