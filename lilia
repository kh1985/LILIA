def profile_sections(profile: str) -> dict[str, str]:
    sections: dict[str, list[str]] = {}
    current: Optional[str] = None
    for line in profile.splitlines():
        match = re.match(r"^##\s+(.+?)\s*$", line)
        if match:
            current = match.group(1).strip()
            sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)
    return {key: "\n".join(lines).strip() for key, lines in sections.items()}


def profile_clean_line(line: str) -> str:
    return re.sub(r"^[-*]\s*", "", line.strip()).strip()


def profile_unlabeled_value(line: str) -> str:
    if ":" not in line:
        return line
    label, value = line.split(":", 1)
    if label.strip() in {"まだ言わないこと", "すぐには開示しない理由"}:
        return value.strip()
    return line


def profile_phrase(text: str) -> str:
    phrase = re.sub(r"[。.!！?？]+$", "", text.strip())
    phrase = re.sub(r"(がある|が残っている|が見える)$", "", phrase).strip()
    return phrase


def profile_short_items(text: str, limit: int = 3) -> str:
    phrase = profile_phrase(text)
    parts = [part.strip() for part in re.split(r"[、,/]+", phrase) if part.strip()]
    if not parts:
        return phrase
    return "、".join(parts[:limit])


def profile_place_focus(text: str) -> str:
    phrase = profile_phrase(text)
    if "コンビニ" in phrase:
        return "雨のコンビニ前" if "雨" in phrase else "コンビニ前"
    if "店先" in phrase:
        return "雨宿りしている店先" if "雨" in phrase else "店先"
    if "駅" in phrase:
        return "駅前" if "駅前" in phrase else "駅"
    if "帰り道" in phrase:
        return "帰り道"
    return phrase


def profile_entry_focus(text: str) -> str:
    phrase = profile_phrase(text)
    if "帰るタイミング" in phrase:
        return "帰るタイミング"
    if "スマホ" in phrase or "通知" in phrase:
        return "スマホ通知"
    if "買い物" in phrase:
        return "手元の買い物"
    if len(phrase) > 28:
        return "次の行動の判断"
    return phrase


def profile_value(
    sections: dict[str, str],
    section_names: list[str],
    labels: list[str],
    fallback: str = "",
) -> str:
    for section_name in section_names:
        section = sections.get(section_name, "")
        for raw_line in section.splitlines():
            line = profile_clean_line(raw_line)
            for label in labels:
                if line.startswith(f"{label}:"):
                    value = line.split(":", 1)[1].strip()
                    if value and value not in {"未設定", "未確定", "SOURCE_FALLBACK"}:
                        return value
    return fallback


def profile_bullets(sections: dict[str, str], section_name: str) -> list[str]:
    result: list[str] = []
    for raw_line in sections.get(section_name, "").splitlines():
        line = profile_clean_line(raw_line)
        if not line or line in {"未設定", "未確定"}:
            continue
        if line.endswith(":"):
            continue
        result.append(profile_unlabeled_value(line))
    return result


def bullet_lines(items: list[str], fallback: str = "未設定") -> str:
    clean = [item for item in items if item and item != "未設定"]
    if not clean:
        clean = [fallback]
    return "\n".join(f"- {item}" for item in clean)


def infer_scene_time(text: str) -> str:
    if "夜" in text:
        return "夜。店の明かりと雨音が残る時間。"
    if "朝" in text:
        return "朝。まだ人の流れが落ち着かない時間。"
    if "夕" in text or "帰" in text:
        return "夕方から夜にかけて。帰る判断をする時間。"
    if "雨" in text:
        return "雨が続く、足を止めるしかない時間。"
    return "初回scene開始時点。次の行動を決める直前。"


def infer_scene_exit_beats(text: str, name: str) -> list[str]:
    beats: list[str] = []
    if "雨" in text:
        beats.append("雨が弱まり、軒下から出る判断ができる")
    if "通知" in text or "スマホ" in text or "連絡" in text:
        beats.append("スマホ通知が来て、返事をするか迷う")
    if "帰" in text or "部屋" in text:
        beats.append(f"{name}が帰る判断をする")
    if "紙袋" in text or "荷物" in text or "トート" in text:
        beats.append("紙袋や荷物の持ち方をどうするかが小さな共同作業になる")
    beats.extend(
        [
            "一緒に途中まで歩く / ここで別れる余地が出る",
            "連絡先を聞くか、次に会う理由だけを残す余地が出る",
        ]
    )
    deduped: list[str] = []
    for beat in beats:
        if beat not in deduped:
            deduped.append(beat)
    return deduped[:5]


def render_profile_initialized_documents(profile: str, answers: Optional[dict[int, str]] = None) -> dict[str, str]:
    answers = answers or {}
    sections = profile_sections(profile)
    name = extract_profile_name(profile) or "LILIA"
    q = lambda number: answer(answers, number) if number in answers else ""
    place = profile_value(
        sections,
        ["Initial Scene Anchors", "everyday anchors", "context"],
        ["場所と状況", "生活の場所", "初回scene開始時点の状況"],
        q(3) or "日常の用事が残る場所",
    )
    objects = profile_value(
        sections,
        ["Initial Scene Anchors", "everyday anchors"],
        ["手元の具体物", "初回sceneで使える具体物", "よく触る物"],
        q(6) or "手元に残っている小さな持ち物",
    )
    distance = profile_value(
        sections,
        ["Initial Scene Anchors", "context"],
        ["最初の距離", "ユーザーとの関係位置"],
        q(5) or "互いをまだ深く知らない距離",
    )
    entry = profile_value(
        sections,
        ["Initial Scene Anchors", "context"],
        ["会話の入口", "初回sceneの生活上の用事"],
        q(6) or "生活上の小さな用事が会話のきっかけになる",
    )
    unspoken = profile_bullets(sections, "unspoken")
    contradictions = profile_bullets(sections, "contradictions")
    values = profile_bullets(sections, "values")
    forbidden = profile_bullets(sections, "forbidden")
    personality = profile_bullets(sections, "personality")
    reactions = profile_bullets(sections, "reactions")
    memories = profile_bullets(sections, "memories")
    fixed_memory = profile_bullets(sections, "fixed memory")
    relationship_progression = profile_bullets(sections, "Relationship Progression")
    voice_progression = profile_bullets(sections, "voice by relationship stage")
    tone_rule = profile_value(sections, ["tone"], ["rule"], "profile.md の tone に従う")
    role = profile_value(sections, ["基礎情報"], ["role"], "初回scene前にprofileから読む")
    combined_text = " / ".join([place, objects, distance, entry, " / ".join(unspoken), " / ".join(contradictions)])
    scene_time = infer_scene_time(combined_text)
    exit_beats = infer_scene_exit_beats(combined_text, name)
    pressure = unspoken[0] if unspoken else (contradictions[0] if contradictions else "まだ言わないことが残っている")
    friction = contradictions[0] if contradictions else pressure
    guard = values[0] if values else "自分で決める余地"
    avoid = forbidden[0] if forbidden else "急に距離を詰められること"
    theme = "近さと主体性。助けることと奪うことの違い。"
    place_phrase = profile_place_focus(place)
    object_phrase = profile_phrase(objects)
    object_focus = profile_short_items(objects)
    entry_phrase = profile_phrase(entry)
    entry_focus = profile_entry_focus(entry)
    action_handles = [
        f"{name}に名乗る / 名前を聞く",
        f"{object_focus}に触れず、扱い方だけを提案する",
        f"{entry_focus}について、急かさず短く聞く",
        f"{name}が自分で決めるまで待つ",
    ]

    return {
        "current/scene.md": render_document(
            "Scene",
            "profile.md の Initial Scene Anchors / context / everyday anchors から初回scene前に初期化した現在場面です。",
            [
                ("今いる場所", bullet_lines([place])),
                ("現在時刻または場面時間", bullet_lines([scene_time])),
                ("LILIAとユーザーの距離", bullet_lines([distance])),
                ("今この場で見えているもの", bullet_lines([objects])),
                ("初回sceneの入口", bullet_lines([entry])),
                ("次に起きそうなこと", bullet_lines(exit_beats[:3])),
                ("次にユーザーへ渡す行動余地", bullet_lines(action_handles)),
            ],
        ),
        "current/event_card.md": render_document(
            "Event Card",
            "profile.md 由来の具体物、保留、矛盾を、今触れる可視イベントへ変換した初回eventです。",
            [
                ("表の出来事", bullet_lines([entry])),
                (
                    "Visible Problem",
                    bullet_lines(
                        [
                            f"{name}は{place_phrase}で足を止めている。",
                            f"手元には{object_phrase}があり、会話や共同作業の入口になる。",
                            f"内側には {pressure} が残っているが、初回で全部は言わない。",
                        ]
                    ),
                ),
                (
                    "First Concrete Action",
                    bullet_lines([f"{name}に声をかけ、{object_focus}には触れずに、{entry_focus}だけを短く確認する。ただし無断接触せず、確認してから近づく。"]),
                ),
                ("Handles 2-4", bullet_lines(action_handles)),
                (
                    "Relationship Stake",
                    bullet_lines([f"距離: {distance}", f"摩擦: {friction}", "境界線を尊重できる相手かを見る。"]),
                ),
                ("If Ignored", bullet_lines([f"{name}は自分だけで判断し、{entry_focus}を抱えたまま次の行動へ移る。", pressure])),
                ("Next Visible Change", bullet_lines(exit_beats[:2])),
                ("Scene Exit / Next Beat", bullet_lines(exit_beats)),
            ],
        ),
        "story/story_deck.md": render_document(
            "Story Deck",
            "profile.md 由来の素材を、初回scene後も戻せる未回収札として整理します。",
            [
                ("現在使えるstory素材", bullet_lines([place, objects, entry, pressure])),
                ("初回sceneで使う小さな出来事", bullet_lines([entry])),
                ("関係を揺らす圧", bullet_lines([pressure, friction])),
                ("未回収札", bullet_lines(unspoken[:3] + contradictions[:2])),
                ("1-3 scene後に戻る圧", bullet_lines(exit_beats)),
            ],
        ),
        "story/relationship_spine.md": render_document(
            "Relationship Spine",
            "初回sceneを固定ルートにせず、関係の変化方向だけを保持します。",
            [
                ("この関係で育てたいテーマ", bullet_lines([theme])),
                ("最初の摩擦", bullet_lines([friction])),
                ("LILIAが守るもの", bullet_lines([guard])),
