def session_sort_value(path: Path) -> str:
    data = read_session_json(path)
    if data.get("created_at"):
        return str(data["created_at"])
    return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat()


def create_session(name: Optional[str]) -> Path:
    if not TEMPLATE_DIR.exists():
        die("templates/session/ is missing")
    if name is None:
        name = next_session_name()
    else:
        validate_session_name(name)
        SAVES_DIR.mkdir(exist_ok=True)

    dest = session_dir(name)
    if dest.exists():
        die(f"session already exists: {dest.relative_to(ROOT)}")

    shutil.copytree(TEMPLATE_DIR, dest)
    data = read_session_json(dest)
    now = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    data["session_id"] = name
    data["session_name"] = name
    data["created_at"] = now
    data["mode"] = "new"
    data["current_phase"] = data.get("current_phase") or "qa_pending"
    data["active_lilia"] = data.get("active_lilia") or "main"
    ensure_lilia_names(data)
    ensure_autosave(data)
    write_session_json(dest, data)
    return dest


def session_candidates() -> list[Path]:
    if not SAVES_DIR.exists():
        return []
    return sorted(
        [path for path in SAVES_DIR.iterdir() if path.is_dir() and (path / "session.json").exists()],
        key=session_sort_value,
        reverse=True,
    )


def latest_session() -> Path:
    candidates = session_candidates()
    if not candidates:
        die("no sessions found; run './lilia new' first")
    return candidates[0]


def resolve_session(name: Optional[str]) -> Path:
    if name is None:
        return latest_session()
    path = session_dir(name)
    if not path.exists():
        die(f"session not found: {path.relative_to(ROOT)}")
    if not (path / "session.json").exists():
        die(f"session.json not found in {path.relative_to(ROOT)}")
    return path


def print_file(path: Path) -> None:
    print(render_file(path))


def render_file(path: Path) -> str:
    if not path.exists():
        return f"\n--- {path.relative_to(ROOT)} (missing) ---"
    return f"\n--- {path.relative_to(ROOT)} ---\n{path.read_text(encoding='utf-8').rstrip()}"


def codex_prompt_path(session_path: Path, mode: str) -> Path:
    safe_name = re.sub(r"[^A-Za-z0-9_.-]", "_", session_path.name)
    return Path("/tmp") / f"lilia_{safe_name}_{mode}_prompt.md"


def write_prompt_file(path: Path, bundle: str) -> None:
    path.write_text(bundle, encoding="utf-8")


def build_new_prompt_bundle(session_path: Path) -> str:
    parts = [
        "# LILIA New Prompt Bundle",
        f"session: {session_path.relative_to(ROOT)}",
        "mode: new",
        "next: answer prompt/newgame.md Q&A, generate/read lilia/main/profile.md, then write the first scene.",
        "important: do not stop at first_scene_pending/first_scene_ready unless the user explicitly asks to pause.",
        "note: --prompt-only only prints this bundle; if you are reading it inside an AI CLI, follow the mode instructions.",
    ]
    parts.extend(render_file(ROOT / rel) for rel in NEW_PROMPT_FILES)
    parts.append(render_file(session_path / "session.json"))
    return "\n".join(parts).rstrip() + "\n"


def build_resume_prompt_bundle(session_path: Path) -> str:
    include_profile = resume_requires_profile(session_path)
    parts = [
        "# LILIA Resume Prompt Bundle",
        f"session: {session_path.relative_to(ROOT)}",
        "mode: resume",
        "read order: prompt/save_resume.md lightweight resume order",
        (
            "profile: included because first scene is ready/pending"
            if include_profile
            else "profile: omitted by default; read lilia/main/profile.md only for voice/personality drift or initial-core checks"
        ),
        "note: --prompt-only only prints this bundle; if you are reading it inside an AI CLI, follow the mode instructions.",
    ]
    parts.extend(render_file(ROOT / rel) for rel in RESUME_PROMPT_FILES)
    for rel in RESUME_SESSION_FILES:
        parts.append(render_file(session_path / rel))
        if rel == "lilia/main/core.md" and include_profile:
            parts.append(render_file(session_path / RESUME_PROFILE_FILE))
    return "\n".join(parts).rstrip() + "\n"


def resume_requires_profile(session_path: Path) -> bool:
    data = read_session_json(session_path)
    if data.get("current_phase") in {"first_scene_pending", "first_scene_ready"}:
        return True
    initialization = data.get("initialization")
    if isinstance(initialization, dict):
        return (
            initialization.get("qa_completed") is True
            and initialization.get("first_scene_status") in {"not_generated", "ready"}
        )
    return False


def print_new_prompt_bundle(session_path: Path) -> None:
    print(build_new_prompt_bundle(session_path), end="")


def print_resume_prompt_bundle(session_path: Path) -> None:
    print(build_resume_prompt_bundle(session_path), end="")


