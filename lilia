        "If needed after a normal play turn, run ./lilia scene-tick "
        f"{session_path.name} only as an autosave counter tick; it is not a save. If autosave_required becomes true, "
        "suggest saving but do not run apply-turn unless the user asks. Do not expose internal save reasoning to the player."
    )


def print_codex_interactive_steps(session_path: Path, prompt_path: Path, mode: str) -> None:
    instruction = codex_interactive_instruction(prompt_path, mode, session_path)
    command = shlex.join(codex_interactive_command(instruction))
    print(f"session: {session_path.relative_to(ROOT)}", flush=True)
    print(f"mode: codex interactive {mode}", flush=True)
    print(f"prompt bundle: {prompt_path}", flush=True)
    print("note: --run uses one-shot 'codex exec'; this flow opens Codex interactive play.", flush=True)
    print("launching Codex interactive with initial instruction:", flush=True)
    print(f"  {instruction}", flush=True)
    print("command:", flush=True)
    print(f"  {command}", flush=True)


def print_codex_interactive_fallback(instruction: str) -> None:
    print("fallback: open Codex interactive manually, then paste:", flush=True)
    print(f"  {instruction}", flush=True)


def maybe_launch_codex_interactive(prompt_path: Path, mode: str, session_path: Path) -> None:
    instruction = codex_interactive_instruction(prompt_path, mode, session_path)
    if not shutil.which("codex"):
        print("codex: not found; install/login to Codex CLI.", flush=True)
        print_codex_interactive_fallback(instruction)
        return
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        print("codex: interactive launch skipped because this shell is not a TTY.", flush=True)
        print_codex_interactive_fallback(instruction)
        return

    print("launching Codex interactive now.", flush=True)
    result = subprocess.run(codex_interactive_command(instruction), cwd=ROOT)
    if result.returncode != 0:
        print(f"codex: interactive launch exited with status {result.returncode}.", flush=True)
        print_codex_interactive_fallback(instruction)


def engine_command(engine: str) -> list[str]:
    if engine == "codex":
        return [
            "codex",
            "exec",
            "--cd",
            str(ROOT),
            "--sandbox",
            "read-only",
            "--color",
            "never",
            "-",
        ]
    if engine == "claude":
        return ["claude", "-p", "--permission-mode", "dontAsk"]
    die(f"unsupported engine: {engine}")


def run_engine(requested_engine: str, session_path: Path, bundle: str) -> None:
    engine = choose_engine(requested_engine)
    if engine is None:
        die(
            "no AI CLI found for --run. Install codex or claude, or use "
            f"'./lilia resume {session_path.name} --prompt-only'."
        )

    print(f"session: {session_path.relative_to(ROOT)}", flush=True)
    print(f"engine: {engine} (requested: {requested_engine})", flush=True)
    print("mode: run", flush=True)
    if engine == "codex":
        print("note: codex engine uses one-shot 'codex exec'; use codex-new/codex-resume for interactive play.", flush=True)
    print("note: prompt bundle is written to a temporary file and removed after the engine exits.", flush=True)

    temp_path: Optional[Path] = None
    try:
        with tempfile.NamedTemporaryFile(
            mode="w",
            encoding="utf-8",
            prefix=f"lilia_{session_path.name}_",
            suffix=".prompt.md",
            delete=False,
        ) as temp_file:
            temp_file.write(bundle)
            temp_path = Path(temp_file.name)

        print(f"prompt bundle: {temp_path}", flush=True)
        with temp_path.open("r", encoding="utf-8") as prompt_file:
            result = subprocess.run(engine_command(engine), stdin=prompt_file, cwd=ROOT)
        if result.returncode != 0:
            die(f"{engine} exited with status {result.returncode}", result.returncode)
    finally:
        if temp_path and temp_path.exists():
            temp_path.unlink()


def command_new(args: list[str]) -> None:
    interactive_requested = "--interactive" in args
    args = [arg for arg in args if arg != "--interactive"]
    args, prompt_only, run, engine = parse_run_options(args)
    if len(args) > 1:
        die("new accepts at most one session_name")
    session_path = create_session(args[0] if args else None)
    print(f"created: {session_path.relative_to(ROOT)}", flush=True)
    if run:
        run_engine(engine, session_path, build_new_prompt_bundle(session_path))
    elif prompt_only:
        print_new_prompt_bundle(session_path)
    else:
        run_newgame_interactive(session_path, engine, interactive_requested=interactive_requested)


def command_resume(args: list[str]) -> None:
    args, prompt_only, run, engine = parse_run_options(args)
    if len(args) > 1:
        die("resume accepts at most one session_name")
    session_path = resolve_session(args[0] if args else None)
    if run:
        run_engine(engine, session_path, build_resume_prompt_bundle(session_path))
    else:
        print(f"session: {session_path.relative_to(ROOT)}", flush=True)
        if prompt_only:
            print_resume_prompt_bundle(session_path)
        else:
            print(f"prompt: ./lilia resume {session_path.name} --prompt-only")
            print(f"run:    ./lilia resume {session_path.name} --run --engine auto")


def command_codex_new(args: list[str]) -> None:
