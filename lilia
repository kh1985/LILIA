def normalize_newgame_answers(raw_answers: dict[int | str, str]) -> dict[int | str, str]:
    answers: dict[int | str, str] = dict(raw_answers)
    if answer_has_value(answers, 9):
        question_count = 9
        answer_format = "wave101_q1_q9"
    elif answer_has_value(answers, 7) or answer_has_value(answers, 8):
        question_count = 8
        answer_format = "wave7_q1_q8_legacy"
    else:
        question_count = 6
        answer_format = "wave10_q1_q6"
    required_missing = [f"Q{number}" for number in range(1, question_count + 1) if not str(answers.get(number, "")).strip()]
    if required_missing:
        die(f"answers.md is missing non-empty sections: {', '.join(required_missing)}")

    answers["format"] = answer_format
    for number in range(1, question_count + 1):
        answers[f"q{number}"] = str(answers[number]).strip()
    return answers


def parse_newgame_answers(path: Path) -> dict[int | str, str]:
    if not path.exists():
        die(f"answers file not found: {path}")
    content = path.read_text(encoding="utf-8")
    sections: dict[int | str, list[str]] = {}
    current: Optional[int] = None
    for line in content.splitlines():
        match = re.match(r"^##\s*Q([1-9])(?:\b|[.\s:：-])", line.strip(), re.IGNORECASE)
        if match:
            current = int(match.group(1))
            sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)

    answers = {number: "\n".join(lines).strip() for number, lines in sections.items()}
    return normalize_newgame_answers(answers)


def normalize_turn_update_heading(heading: str) -> str:
