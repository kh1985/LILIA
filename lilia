def story_fields_from_story_spine_markdown(markdown: str) -> dict[str, object]:
    sections = markdown_sections(markdown)
    reveal_items = [
        re.sub(r"^\s*(?:[-*]|\d+[.)])\s*", "", line).strip()
        for line in sections.get("reveal ladder", "").splitlines()
        if re.match(r"^\s*(?:[-*]|\d+[.)])\s+", line)
    ]
    reveal_items = [item for item in reveal_items if item]
    return {
        "background_truth": sections.get("background truth", "") or sections.get("background truth gm only", ""),
        "visible": reveal_items[0] if len(reveal_items) > 0 else "",
        "near_reveal": reveal_items[1] if len(reveal_items) > 1 else "",
        "deep_reveal": reveal_items[2] if len(reveal_items) > 2 else "",
    }


def markdown_sections(markdown: str) -> dict[str, str]:
    matches = list(re.finditer(r"^##\s+(.+?)\s*$", markdown, re.MULTILINE))
    sections: dict[str, str] = {}
    for index, match in enumerate(matches):
        heading = re.sub(r"[\(\（].*?[\)\）]", "", match.group(1)).strip().lower()
        start = match.end()
        end = matches[index + 1].start() if index + 1 < len(matches) else len(markdown)
        sections[heading] = markdown[start:end].strip()
    return sections


