def session_sort_value(path: Path) -> str:
    data = read_session_json(path)
    if data.get("created_at"):
        return str(data["created_at"])
    return datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).isoformat()


def create_session(name: Optional[str]) -> Path:
    if not TEMPLATE_DIR.exists():
        die("templates/session/ is missing")
    if name is None:
        name = next_session_name()
    else:
        validate_session_name(name)
        SAVES_DIR.mkdir(exist_ok=True)

    dest = session_dir(name)
    if dest.exists():
        die(f"session already exists: {dest.relative_to(ROOT)}")

    shutil.copytree(TEMPLATE_DIR, dest)
    protagonist_template = dest / "protagonist.md"
    if protagonist_template.exists():
        write_session_file(dest, "current/protagonist.md", protagonist_template.read_text(encoding="utf-8"))
        protagonist_template.unlink()
    knowledge_state_template = dest / "knowledge_state.md"
    if knowledge_state_template.exists():
        write_session_file(dest, "current/knowledge_state.md", knowledge_state_template.read_text(encoding="utf-8"))
        knowledge_state_template.unlink()
    data = read_session_json(dest)
    now = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    data["session_id"] = name
    data["session_name"] = name
    data["created_at"] = now
    data["mode"] = "new"
    data["current_phase"] = data.get("current_phase") or "qa_pending"
    data["active_lilia"] = data.get("active_lilia") or "main"
    ensure_lilia_names(data)
    ensure_autosave(data)
    write_session_json(dest, data)
    return dest


def session_candidates() -> list[Path]:
    if not SAVES_DIR.exists():
        return []
    return sorted(
        [path for path in SAVES_DIR.iterdir() if path.is_dir() and (path / "session.json").exists()],
        key=session_sort_value,
        reverse=True,
    )


def latest_session() -> Path:
    candidates = session_candidates()
    if not candidates:
        die("no sessions found; run './lilia new' first")
    return candidates[0]


def resolve_session(name: Optional[str]) -> Path:
    if name is None:
        return latest_session()
    path = session_dir(name)
    if not path.exists():
        die(f"session not found: {path.relative_to(ROOT)}")
    if not (path / "session.json").exists():
        die(f"session.json not found in {path.relative_to(ROOT)}")
    return path


def print_file(path: Path) -> None:
    print(render_file(path))


def knowledge_block_known_to_has(block: list[str], actor: str) -> bool:
    in_known_to = False
    actor_pattern = re.compile(rf"\b{re.escape(actor)}\b")
    for line in block:
        stripped = line.strip()
        if stripped.startswith("known_to:"):
            in_known_to = True
            if actor_pattern.search(stripped):
                return True
            if "[" in stripped and "]" in stripped:
                in_known_to = False
            continue
        if in_known_to:
            if actor_pattern.search(stripped):
                return True
            if stripped and not stripped.startswith("-"):
                in_known_to = False
    return False


def sanitize_knowledge_item_for_context(block: list[str]) -> list[str]:
    is_meta = any(
        re.match(r"\s*fictional_status:\s*meta\s*(?:#.*)?$", line)
        for line in block
    )
    heroine_knows = knowledge_block_known_to_has(block, "heroine")
    if not is_meta or heroine_knows:
        return block

    result: list[str] = []
    value_replaced = False
    notes_replaced = False
    for line in block:
        if re.match(r"\s*value:\s*", line):
            indent = re.match(r"^(\s*)", line).group(1)
            result.append(f'{indent}value: "{KNOWLEDGE_HIDDEN_VALUE}"')
            value_replaced = True
            continue
        if re.match(r"\s*notes:\s*", line):
            indent = re.match(r"^(\s*)", line).group(1)
            result.append(f'{indent}notes: "{KNOWLEDGE_HIDDEN_NOTE}"')
            notes_replaced = True
            continue
        result.append(line)

    if not value_replaced:
        for index, line in enumerate(result):
            if re.match(r"\s*-\s+key:\s*", line):
                indent = re.match(r"^(\s*)", line).group(1)
                result.insert(index + 1, f'{indent}  value: "{KNOWLEDGE_HIDDEN_VALUE}"')
                break
    if not notes_replaced:
        result.append(f'    notes: "{KNOWLEDGE_HIDDEN_NOTE}"')
    return result


def sanitize_knowledge_state_for_context(content: str) -> str:
    lines = content.splitlines()
    output: list[str] = []
    current_item: list[str] = []

    for line in lines:
        if re.match(r"\s*-\s+key:\s*", line):
            if current_item:
                output.extend(sanitize_knowledge_item_for_context(current_item))
            current_item = [line]
            continue
        if current_item:
            current_item.append(line)
        else:
            output.append(line)

    if current_item:
        output.extend(sanitize_knowledge_item_for_context(current_item))

    return "\n".join(output)


def split_action_and_monologue(player_input: str) -> tuple[str, str]:
    """Split player-visible action from protagonist inner monologue.

    Parentheses at line start or immediately after half-width whitespace are
    treated as inner monologue. Parentheses directly after a word stay in the
    action text as supplements.
    """

    text = player_input or ""
    action: list[str] = []
    monologues: list[str] = []
    index = 0
    pairs = {"（": "）", "(": ")"}

    while index < len(text):
        char = text[index]
        close = pairs.get(char)
        if not close:
            action.append(char)
            index += 1
            continue

        is_inner_position = index == 0 or text[index - 1] in {" ", "\t", "\n"}
        close_index = text.find(close, index + 1)
        if close_index == -1 or not is_inner_position:
            action.append(char)
            index += 1
            continue

        while action and action[-1] in {" ", "\t"}:
            action.pop()
        inner = text[index + 1 : close_index].strip()
        if inner:
            monologues.append(inner)
        index = close_index + 1

    action_text = re.sub(r"[ \t]{2,}", " ", "".join(action))
    action_text = re.sub(r" *\n *", "\n", action_text).strip()
    monologue_text = " / ".join(monologues)
    return action_text, monologue_text


def format_player_input_boundary(player_input: str) -> str:
    action_text, monologue_text = split_action_and_monologue(player_input)
    return "\n".join(
        [
            "[PLAYER_INNER_MONOLOGUE - GM_ONLY]",
            monologue_text or "なし",
            "[END_INNER_MONOLOGUE]",
            "",
            "[PLAYER_ACTION]",
            action_text or "（行動・発言なし）",
            "[END_PLAYER_ACTION]",
        ]
    )


def render_file(path: Path) -> str:
    if not path.exists():
        return f"\n--- {path.relative_to(ROOT)} (missing) ---"
    content = path.read_text(encoding="utf-8").rstrip()
    if path.name == "knowledge_state.md":
        content = sanitize_knowledge_state_for_context(content)
    return f"\n--- {path.relative_to(ROOT)} ---\n{content}"



def codex_prompt_path(session_path: Path, mode: str) -> Path:
    safe_name = re.sub(r"[^A-Za-z0-9_.-]", "_", session_path.name)
    return Path("/tmp") / f"lilia_{safe_name}_{mode}_prompt.md"


def write_prompt_file(path: Path, bundle: str) -> None:
    path.write_text(bundle, encoding="utf-8")


def run_newgame_interactive(session_path: Path, engine: str, *, interactive_requested: bool = False) -> None:
    del interactive_requested
    print("")
    print(render_interactive_question(NEWGAME_QUESTIONS[0]))
    if not sys.stdin.isatty():
        print("")
        print(f"interactive input requires a TTY. Batch mode: ./lilia new {session_path.name} --prompt-only")
        print(f"apply answers: ./lilia apply-newgame {session_path.name} answers.md --engine {engine}")
        return

    answers: dict[int, str] = {}
    for question in NEWGAME_QUESTIONS:
        number = int(question["number"])
        if number != 1:
            print("")
            print(render_interactive_question(question))
        first = input("> ").strip()
        followup = supplementary_question(number, first)
        if followup:
            print(followup)
            supplement = input("> ").strip()
            if supplement:
                first = f"{first}\n補足: {supplement}" if first else supplement
        answers[number] = first or "おまかせ"

    answers_path = write_interactive_answers_file(session_path, answers)
    print("")
    print(f"answers: {answers_path.relative_to(ROOT)}")
    command_apply_newgame([session_path.name, str(answers_path), "--engine", engine])


def build_new_prompt_bundle(session_path: Path) -> str:
    parts = [
        "# LILIA New Prompt Bundle",
        f"session: {session_path.relative_to(ROOT)}",
        "mode: new",
        "next: answer prompt/newgame.md Q&A, generate/read lilia/main/profile.md, then write the first scene.",
        "important: do not stop at first_scene_pending/first_scene_ready unless the user explicitly asks to pause.",
        "note: --prompt-only only prints this bundle; if you are reading it inside an AI CLI, follow the mode instructions.",
    ]
    parts.extend(render_file(ROOT / rel) for rel in NEW_PROMPT_FILES)
    parts.append(render_file(session_path / "session.json"))
    return "\n".join(parts).rstrip() + "\n"


def build_resume_prompt_bundle(session_path: Path) -> str:
    include_profile = resume_requires_profile(session_path)
    parts = [
        "# LILIA Resume Prompt Bundle",
        f"session: {session_path.relative_to(ROOT)}",
        "mode: resume",
        "read order: prompt/save_resume.md lightweight resume order",
        (
            "profile: included because first scene is ready/pending"
            if include_profile
            else "profile: omitted by default; read lilia/main/profile.md only for voice/personality drift or initial-core checks"
        ),
        "note: --prompt-only only prints this bundle; if you are reading it inside an AI CLI, follow the mode instructions.",
    ]
    parts.extend(render_file(ROOT / rel) for rel in RESUME_PROMPT_FILES)
    for rel in RESUME_SESSION_FILES:
        parts.append(render_file(session_path / rel))
        if rel == "lilia/main/core.md" and include_profile:
            parts.append(render_file(session_path / RESUME_PROFILE_FILE))
    return "\n".join(parts).rstrip() + "\n"


def resume_requires_profile(session_path: Path) -> bool:
    data = read_session_json(session_path)
    if data.get("current_phase") in {"first_scene_pending", "first_scene_ready"}:
        return True
    initialization = data.get("initialization")
    if isinstance(initialization, dict):
        return (
            initialization.get("qa_completed") is True
            and initialization.get("first_scene_status") in {"not_generated", "ready"}
        )
    return False


def print_new_prompt_bundle(session_path: Path) -> None:
    print(build_new_prompt_bundle(session_path), end="")


def print_resume_prompt_bundle(session_path: Path) -> None:
    print(build_resume_prompt_bundle(session_path), end="")


