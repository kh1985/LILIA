        "clean": menu_action_clean,
        "saves": menu_action_saves_view,
        "list": menu_action_list,
        "growth": menu_action_growth,
    }
    while True:
        print(_MENU_HEADER)
        raw = _read_input("> ")
        action = resolve_menu_action(raw)
        if action is None:
            if raw == "":
                print("入力が読み取れませんでした (EOF)。終了します。")
                return
            print(f"認識できませんでした: {raw!r}。もう一度入力してください。")
            continue
