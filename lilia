def explicit_name_from_answers(answers: dict[int | str, str]) -> str:
    q1 = (answers.get(1) or answers.get("q1") or "").strip()
    if q1:
        first_segment = re.split(r"[、,。.\n]|(?:\d{1,3}\s*歳)", q1, maxsplit=1)[0]
        first_segment = re.sub(r"^(?:名前|ヒロイン|基本)\s*(?:は|:|：|=)\s*", "", first_segment.strip())
        if first_segment and not is_non_specific_literal(first_segment) and not q1_name_is_omakase(first_segment):
            name = clean_lilia_name(first_segment)
            if name:
                return name
    patterns = [
        r"(?:名前|個体名|name)\s*(?:は|:|：|=)\s*[「『]?([A-Za-z一-龥ぁ-んァ-ヶー]{1,12})(?=」|』|で|に|と|、|。|\s|$)",
        r"[「『]?([A-Za-z一-龥ぁ-んァ-ヶー]{1,12})[」』]?\s*(?:という|っていう)?\s*名前",
    ]
    for text in answers.values():
        for pattern in patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                name = clean_lilia_name(match.group(1))
                if name:
                    return name
    return ""


