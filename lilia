            print("終了します。")
            return
        handler = actions.get(action)
        if handler is None:
            print(f"未対応のactionです: {action}")
            continue
        try:
            handler()
        except KeyboardInterrupt:
            print("\n中断しました。メニューに戻ります。")
        except SystemExit as exc:
            print(f"\n途中で終了しました (exit={exc.code})。メニューに戻ります。")
