    for path, size in candidates:
        total += size
        print(f"  {path.relative_to(ROOT)}  ({_format_size_h(size)})")
    print(f"合計サイズ: {_format_size_h(total)}")
    print()
    print("削除する場合は半角大文字で 'DELETE' と入力してください。")
    print("それ以外の入力はdry-run扱いで何もしません。")
    confirm = _read_input("> ").strip()
    if confirm != "DELETE":
        print("dry-run: 何も削除していません。")
        return
    deleted = 0
    for path, _ in candidates:
        try:
            shutil.rmtree(path)
            deleted += 1
        except OSError as exc:
            print(f"削除失敗: {path.relative_to(ROOT)}: {exc}")
    print(f"削除: {deleted}/{len(candidates)} run")


def _collect_clean_candidates(min_age_days: int) -> list[tuple[Path, int]]:
    runs = _list_run_dirs()
    if not runs:
        return []
    cutoff = datetime.now(timezone.utc).timestamp() - (min_age_days * 86400)
    candidates: list[tuple[Path, int]] = []
    for path in runs:
        try:
            mtime = path.stat().st_mtime
        except OSError:
            continue
        if mtime <= cutoff:
            candidates.append((path, _format_session_size(path)))
    return candidates


