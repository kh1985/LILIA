def knowledge_block_known_to_has(block: list[str], actor: str) -> bool:
    in_known_to = False
    actor_pattern = re.compile(rf"\b{re.escape(actor)}\b")
    for line in block:
        stripped = line.strip()
        if stripped.startswith("known_to:"):
            in_known_to = True
            if actor_pattern.search(stripped):
                return True
            if "[" in stripped and "]" in stripped:
                in_known_to = False
            continue
        if in_known_to:
            if actor_pattern.search(stripped):
                return True
            if stripped and not stripped.startswith("-"):
                in_known_to = False
    return False


def sanitize_knowledge_item_for_context(block: list[str]) -> list[str]:
    is_meta = any(
        re.match(r"\s*fictional_status:\s*meta\s*(?:#.*)?$", line)
        for line in block
    )
    heroine_knows = knowledge_block_known_to_has(block, "heroine")
    if not is_meta or heroine_knows:
        return block

    result: list[str] = []
    value_replaced = False
    notes_replaced = False
    for line in block:
        if re.match(r"\s*value:\s*", line):
            indent = re.match(r"^(\s*)", line).group(1)
            result.append(f'{indent}value: "{KNOWLEDGE_HIDDEN_VALUE}"')
            value_replaced = True
            continue
        if re.match(r"\s*notes:\s*", line):
            indent = re.match(r"^(\s*)", line).group(1)
            result.append(f'{indent}notes: "{KNOWLEDGE_HIDDEN_NOTE}"')
            notes_replaced = True
            continue
        result.append(line)

    if not value_replaced:
        for index, line in enumerate(result):
            if re.match(r"\s*-\s+key:\s*", line):
                indent = re.match(r"^(\s*)", line).group(1)
                result.insert(index + 1, f'{indent}  value: "{KNOWLEDGE_HIDDEN_VALUE}"')
                break
    if not notes_replaced:
        result.append(f'    notes: "{KNOWLEDGE_HIDDEN_NOTE}"')
    return result


def sanitize_knowledge_state_for_context(content: str) -> str:
    lines = content.splitlines()
    output: list[str] = []
    current_item: list[str] = []

    for line in lines:
        if re.match(r"\s*-\s+key:\s*", line):
            if current_item:
                output.extend(sanitize_knowledge_item_for_context(current_item))
            current_item = [line]
            continue
        if current_item:
            current_item.append(line)
        else:
            output.append(line)

    if current_item:
        output.extend(sanitize_knowledge_item_for_context(current_item))

    return "\n".join(output)


def sanitize_protagonist_for_context(content: str) -> str:
    lines = content.splitlines()
    output: list[str] = []
    in_call_name = False
    note_added = False

    for line in lines:
        if re.match(r"^##\s+呼ばれ方\s*$", line):
            in_call_name = True
            note_added = False
            output.append(line)
            continue
        if in_call_name and re.match(r"^##\s+", line):
            in_call_name = False
            output.append(line)
            continue
        if in_call_name and re.match(r"\s*呼称(?:（[^）]+）)?\s*:", line):
            indent = re.match(r"^(\s*)", line).group(1)
            output.append(f"{indent}呼称（開示後）: {KNOWLEDGE_HIDDEN_VALUE}")
            output.append(f"{indent}注: Q7の希望呼称。ヒロインがscene内で知るまで台詞に使わない。")
            note_added = True
            continue
        if in_call_name and line.strip() and not note_added and "希望呼称" not in line:
            output.append(line)
            continue
        output.append(line)

    return "\n".join(output)


def split_action_and_monologue(player_input: str) -> tuple[str, str]:
    """Split player-visible action from protagonist inner monologue.

    Parentheses at line start or immediately after half-width whitespace are
    treated as inner monologue. Parentheses directly after a word stay in the
    action text as supplements.
    """

    text = player_input or ""
    action: list[str] = []
    monologues: list[str] = []
    index = 0
    pairs = {"（": "）", "(": ")"}

    while index < len(text):
        char = text[index]
        close = pairs.get(char)
        if not close:
            action.append(char)
            index += 1
            continue

        is_inner_position = index == 0 or text[index - 1] in {" ", "\t", "\n"}
        close_index = text.find(close, index + 1)
        if close_index == -1 or not is_inner_position:
            action.append(char)
            index += 1
            continue

        while action and action[-1] in {" ", "\t"}:
            action.pop()
        inner = text[index + 1 : close_index].strip()
        if inner:
            monologues.append(inner)
        index = close_index + 1

    action_text = re.sub(r"[ \t]{2,}", " ", "".join(action))
    action_text = re.sub(r" *\n *", "\n", action_text).strip()
    monologue_text = " / ".join(monologues)
    return action_text, monologue_text


def format_player_input_boundary(player_input: str) -> str:
    action_text, monologue_text = split_action_and_monologue(player_input)
    return "\n".join(
        [
            "[PLAYER_INNER_MONOLOGUE - GM_ONLY]",
            monologue_text or "なし",
            "[END_INNER_MONOLOGUE]",
            "",
            "[PLAYER_ACTION]",
            action_text or "（行動・発言なし）",
            "[END_PLAYER_ACTION]",
        ]
    )


def render_file(path: Path) -> str:
    if not path.exists():
        return f"\n--- {path.relative_to(ROOT)} (missing) ---"
    content = path.read_text(encoding="utf-8").rstrip()
    if path.name == "knowledge_state.md":
        content = sanitize_knowledge_state_for_context(content)
    if path.name == "protagonist.md":
        content = sanitize_protagonist_for_context(content)
    return f"\n--- {path.relative_to(ROOT)} ---\n{content}"



