def profile_sections(profile: str) -> dict[str, str]:
    sections: dict[str, list[str]] = {}
    current: Optional[str] = None
    for line in profile.splitlines():
        match = re.match(r"^##\s+(.+?)\s*$", line)
        if match:
            heading = match.group(1).strip()
            current = "context" if heading.startswith("context ") else heading
            sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)
    return {key: "\n".join(lines).strip() for key, lines in sections.items()}


def profile_clean_line(line: str) -> str:
    return re.sub(r"^[-*]\s*", "", line.strip()).strip()


def profile_unlabeled_value(line: str) -> str:
    if ":" not in line:
        return line
    label, value = line.split(":", 1)
    if label.strip() in {"まだ言わないこと", "すぐには開示しない理由"}:
        return value.strip()
    return line


def profile_line_value(line: str) -> str:
    return line.split(":", 1)[1].strip() if ":" in line else line.strip()


def profile_phrase(text: str) -> str:
    phrase = re.sub(r"[。.!！?？]+$", "", text.strip())
    phrase = re.sub(r"(がある|が残っている|が見える)$", "", phrase).strip()
    return phrase


def profile_short_items(text: str, limit: int = 3) -> str:
    phrase = profile_phrase(text)
    parts = [part.strip() for part in re.split(r"[、,/]+", phrase) if part.strip()]
    if not parts:
        return phrase
    return "、".join(parts[:limit])


def profile_place_focus(text: str) -> str:
    phrase = profile_phrase(text)
    return phrase


def profile_entry_focus(text: str) -> str:
    phrase = profile_phrase(text)
    if len(phrase) > 28:
        return "次の行動の判断"
    return phrase


def profile_value(
    sections: dict[str, str],
    section_names: list[str],
    labels: list[str],
    fallback: str = "",
) -> str:
    for section_name in section_names:
        section = sections.get(section_name, "")
        for raw_line in section.splitlines():
            line = profile_clean_line(raw_line)
            for label in labels:
                if line.startswith(f"{label}:"):
                    value = line.split(":", 1)[1].strip()
                    if not is_unconfirmed_value(value):
                        return value
    return fallback


def profile_bullets(sections: dict[str, str], section_name: str) -> list[str]:
    result: list[str] = []
    for raw_line in sections.get(section_name, "").splitlines():
        line = profile_clean_line(raw_line)
        if is_unconfirmed_value(line) or is_unconfirmed_value(profile_line_value(line)):
            continue
        if line.endswith(":"):
            continue
        result.append(profile_unlabeled_value(line))
    return result


def bullet_lines(items: list[str], fallback: str = "未設定") -> str:
    clean = [item for item in items if item and not is_unconfirmed_value(item)]
    if not clean:
        clean = [fallback]
    return "\n".join(f"- {item}" for item in clean)


def is_unconfirmed_value(value: str) -> bool:
    text = value.strip()
    return not text or is_non_specific_literal(text) or "LLM CLI で再生成推奨" in text


GENERIC_NEWGAME_ANSWERS = NON_SPECIFIC_VALUES


def story_clean_answer(value: str, fallback: str = "") -> str:
    text = re.sub(r"\s+", " ", (value or "").replace("\n", " / ")).strip()
    compact = re.sub(r"\s+", "", text).strip("「」『』'\"")
    if compact in GENERIC_NEWGAME_ANSWERS or is_unconfirmed_value(text):
        return fallback
    return text


def story_short_clause(value: str, limit: int = 70) -> str:
    text = story_clean_answer(value)
    if not text:
        return ""
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip("、。/ ") + "…"


def story_fragment(value: str, limit: int = 70) -> str:
    return story_short_clause(value, limit).rstrip("。.!！?？")


def infer_scene_time(text: str) -> str:
    value = story_fragment(text, 60)
    if value:
        return f"{value}から導出する場面時間"
    return "[未確定: scene 内で profile.context から導出]"


def infer_scene_exit_beats(text: str, name: str) -> list[str]:
    context = story_fragment(text, 48)
    beats = [
        f"{name}が次の行動を自分で選ぶ余地が出る",
        "ここで別れる / 少し残る / 次に会う理由だけを残す余地が出る",
    ]
    if context:
        beats.insert(0, f"{context}が次の入口として残る")
    deduped: list[str] = []
    for beat in beats:
        if beat not in deduped:
            deduped.append(beat)
    return deduped[:5]


def answer_or_default(answers: dict[int | str, str], number: int, default: str) -> str:
    value = answer(answers, number).replace("\n", " / ").strip()
    if not value:
        return default
    if is_non_specific_literal(value):
        return default
    return value


def infer_protagonist_body_fields(body_style: str) -> tuple[str, str, str, str]:
    compact = re.sub(r"\s+", "", body_style)
    sex = "未確定"
    if "女" in compact:
        sex = "女"
    elif "男" in compact:
        sex = "男"

    height = "未確定"
    cm_match = re.search(r"(\d{2,3}\s*cm)", body_style, re.IGNORECASE)
    if cm_match:
        height = cm_match.group(1).replace(" ", "")
    elif any(word in compact for word in ["高め", "高い", "長身"]):
        height = "高め"
    elif any(word in compact for word in ["低め", "低い", "小柄", "背が低"]):
        height = "低め"
    elif any(word in compact for word in ["中くらい", "中肉中背", "中背"]):
        height = "中くらい"

    build = "未確定"
    if "細身" in compact:
        build = "細身"
    elif any(word in compact for word in ["がっしり", "筋肉質"]):
        build = "がっしり"
    elif any(word in compact for word in ["普通", "中肉中背", "中肉"]):
        build = "普通"

    clothes = body_style if body_style else "未確定"
    return sex, height, build, clothes


def infer_protagonist_job_field(body_style: str) -> str:
    if not body_style or is_non_specific_literal(body_style):
        return "未確定: scene 内で開示"
    parts = [part.strip() for part in re.split(r"[、,/／。]+", body_style.replace("\n", " / ")) if part.strip()]
    job_words = ["会社員", "自営業", "フリーランス", "店員", "職", "仕事", "勤務", "デザイナー", "エンジニア", "教師", "医師", "学生", "作家", "便利屋"]
    for part in parts:
        if any(word in part for word in job_words):
            return part
    if len(parts) >= 5:
        return parts[-1]
    return "未確定: scene 内で開示"


def yaml_scalar(value: str) -> str:
    clean = (value or "未確定").replace("\n", " / ").strip() or "未確定"
    escaped = clean.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{escaped}"'


def yaml_list(values: list[str]) -> str:
    clean: list[str] = []
    for value in values:
        item = re.sub(r"^[\[\]\s]+|[\]\s]+$", "", value.strip())
        if item and item not in clean:
            clean.append(item)
    return "[" + ", ".join(clean or ["GM"]) + "]"


def knowledge_item_yaml(
    *,
    key: str,
    value: str,
    fictional_status: str,
    source: str,
    known_to: list[str],
    acquired_at: str,
    weight: str,
    notes: str = "",
) -> list[str]:
    lines = [
        f"  - key: {key}",
        f"    value: {yaml_scalar(value)}",
        f"    fictional_status: {fictional_status}",
        f"    source: {source}",
        f"    known_to: {yaml_list(known_to)}",
        f"    acquired_at: {acquired_at}",
        f"    weight: {weight}",
    ]
    if notes:
        lines.append(f"    notes: {yaml_scalar(notes)}")
    return lines


def _extract_fenced_yaml_with_items(markdown: str) -> str:
    knowledge_match = re.search(
        r"^##\s+knowledge_state\s*$.*?```(?:yaml)?\s*\n(.*?)\n```",
        markdown,
        flags=re.MULTILINE | re.DOTALL | re.IGNORECASE,
    )
    if knowledge_match:
        return knowledge_match.group(1)
    for match in re.finditer(r"```(?:yaml)?\s*\n(.*?)\n```", markdown, re.DOTALL | re.IGNORECASE):
        block = match.group(1)
        if re.search(r"^\s*items\s*:", block, re.MULTILINE):
            return block
    return ""


def _knowledge_items_by_key(markdown: str) -> dict[str, dict[str, object]]:
    block = _extract_fenced_yaml_with_items(markdown)
    if not block.strip():
        return {}
    try:
        import yaml

        parsed = yaml.safe_load(block)
        items = parsed.get("items") if isinstance(parsed, dict) else None
        if isinstance(items, list):
            return {
                str(item["key"]): item
                for item in items
                if isinstance(item, dict) and item.get("key")
            }
    except Exception:
        pass

    items_by_key: dict[str, dict[str, object]] = {}
    current: dict[str, object] | None = None
    for raw_line in block.splitlines():
        key_match = re.match(r"\s*-\s+key:\s*(.+?)\s*$", raw_line)
        if key_match:
            current = {"key": key_match.group(1).strip().strip('"')}
            items_by_key[str(current["key"])] = current
            continue
        field_match = re.match(r"\s+([A-Za-z0-9_]+):\s*(.*?)\s*$", raw_line)
        if field_match and current is not None:
            current[field_match.group(1)] = field_match.group(2).strip().strip('"')
    return items_by_key


def _protagonist_value_from_document(markdown: str, labels: list[str], default: str = "未確定") -> str:
    for label in labels:
        match = re.search(rf"{re.escape(label)}\s*[:：]\s*(.+)", markdown)
        if match:
            value = match.group(1).strip()
            if value:
                return value
    return default


def _knowledge_value(items_by_key: dict[str, dict[str, object]], key: str, fallback: str) -> str:
    item = items_by_key.get(key)
    if isinstance(item, dict):
        value = str(item.get("value") or "").strip()
        if value:
            return value
    return fallback


