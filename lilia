def generate_downstream_session_documents(
    *,
    answers: dict[int | str, str],
    profile_md: str,
    character_yaml: dict[str, object],
    story_spine_md: str,
    relationship_spine_md: str,
    lilia_name: str,
    engine: str,
    session_name: str,
) -> dict[str, object]:
    try:
        from tools.session.document_generator import generate_session_documents
    except ModuleNotFoundError as exc:
        raise RuntimeError(
            "tools.session.document_generator.generate_session_documents is required for Wave 12.2"
        ) from exc
    except Exception as exc:
        raise RuntimeError(f"failed to import session document generator: {exc}") from exc

    result = generate_session_documents(
        answers=answers,
        character_yaml=character_yaml,
        profile_md=profile_md,
        story_spine_md=story_spine_md,
        relationship_spine_md=relationship_spine_md,
        engine=engine,
        lilia_name=lilia_name,
        session_name=session_name,
        logger=globals().get("_CURRENT_OPERATION_LOGGER"),
    )
    if isinstance(result, dict) and "documents" in result and isinstance(result["documents"], dict):
        raw_documents = result["documents"]
    elif isinstance(result, dict) and "session_documents" in result and isinstance(result["session_documents"], dict):
        raw_documents = result["session_documents"]
    elif hasattr(result, "documents"):
        raw_documents = getattr(result, "documents")
    elif hasattr(result, "session_documents"):
        raw_documents = getattr(result, "session_documents")
    else:
        raw_documents = result

    if not isinstance(raw_documents, dict):
        raise RuntimeError("session document generator must return a dict of relative paths to markdown content")

    documents = {str(path): str(content) for path, content in raw_documents.items()}
    missing = [path for path in DOWNSTREAM_SESSION_DOCUMENT_FILES if not documents.get(path, "").strip()]
    if missing:
        raise RuntimeError(
            "session document generator did not produce required downstream files: "
            + ", ".join(missing)
        )
    if isinstance(result, dict):
        normalized = dict(result)
    else:
        normalized = {}
    normalized["documents"] = {path: documents[path] for path in DOWNSTREAM_SESSION_DOCUMENT_FILES}
    return normalized


def markdown_sections(markdown: str) -> dict[str, str]:
    matches = list(re.finditer(r"^##\s+(.+?)\s*$", markdown, re.MULTILINE))
    sections: dict[str, str] = {}
    for index, match in enumerate(matches):
        heading = re.sub(r"[\(\（].*?[\)\）]", "", match.group(1)).strip().lower()
        start = match.end()
        end = matches[index + 1].start() if index + 1 < len(matches) else len(markdown)
        sections[heading] = markdown[start:end].strip()
    return sections


