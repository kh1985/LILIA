def profile_sections(profile: str) -> dict[str, str]:
    sections: dict[str, list[str]] = {}
    current: Optional[str] = None
    for line in profile.splitlines():
        match = re.match(r"^##\s+(.+?)\s*$", line)
        if match:
            heading = match.group(1).strip()
            current = "context" if heading.startswith("context ") else heading
            sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)
    return {key: "\n".join(lines).strip() for key, lines in sections.items()}


def profile_clean_line(line: str) -> str:
    return re.sub(r"^[-*]\s*", "", line.strip()).strip()


def profile_unlabeled_value(line: str) -> str:
    if ":" not in line:
        return line
    label, value = line.split(":", 1)
    if label.strip() in {"まだ言わないこと", "すぐには開示しない理由"}:
        return value.strip()
    return line


def profile_line_value(line: str) -> str:
    return line.split(":", 1)[1].strip() if ":" in line else line.strip()


def profile_phrase(text: str) -> str:
    phrase = re.sub(r"[。.!！?？]+$", "", text.strip())
    phrase = re.sub(r"(がある|が残っている|が見える)$", "", phrase).strip()
    return phrase


def profile_short_items(text: str, limit: int = 3) -> str:
    phrase = profile_phrase(text)
    parts = [part.strip() for part in re.split(r"[、,/]+", phrase) if part.strip()]
    if not parts:
        return phrase
    return "、".join(parts[:limit])


def profile_place_focus(text: str) -> str:
    phrase = profile_phrase(text)
    if "コンビニ" in phrase:
        return "雨のコンビニ前" if "雨" in phrase else "コンビニ前"
    if "店先" in phrase:
        return "雨宿りしている店先" if "雨" in phrase else "店先"
    if "駅" in phrase:
        return "駅前" if "駅前" in phrase else "駅"
    if "帰り道" in phrase:
        return "帰り道"
    return phrase


def profile_entry_focus(text: str) -> str:
    phrase = profile_phrase(text)
    if "帰るタイミング" in phrase:
        return "帰るタイミング"
    if "スマホ" in phrase or "通知" in phrase:
        return "スマホ通知"
    if "買い物" in phrase:
        return "手元の買い物"
    if len(phrase) > 28:
        return "次の行動の判断"
    return phrase


def profile_value(
    sections: dict[str, str],
    section_names: list[str],
    labels: list[str],
    fallback: str = "",
) -> str:
    for section_name in section_names:
        section = sections.get(section_name, "")
        for raw_line in section.splitlines():
            line = profile_clean_line(raw_line)
            for label in labels:
                if line.startswith(f"{label}:"):
                    value = line.split(":", 1)[1].strip()
                    if not is_unconfirmed_value(value):
                        return value
    return fallback


def profile_bullets(sections: dict[str, str], section_name: str) -> list[str]:
    result: list[str] = []
    for raw_line in sections.get(section_name, "").splitlines():
        line = profile_clean_line(raw_line)
        if is_unconfirmed_value(line) or is_unconfirmed_value(profile_line_value(line)):
            continue
        if line.endswith(":"):
            continue
        result.append(profile_unlabeled_value(line))
    return result


def bullet_lines(items: list[str], fallback: str = "未設定") -> str:
    clean = [item for item in items if item and not is_unconfirmed_value(item)]
    if not clean:
        clean = [fallback]
    return "\n".join(f"- {item}" for item in clean)


def is_unconfirmed_value(value: str) -> bool:
    text = value.strip()
    return not text or is_non_specific_literal(text) or "LLM CLI で再生成推奨" in text


GENERIC_NEWGAME_ANSWERS = NON_SPECIFIC_VALUES


def story_clean_answer(value: str, fallback: str = "") -> str:
    text = re.sub(r"\s+", " ", (value or "").replace("\n", " / ")).strip()
    compact = re.sub(r"\s+", "", text).strip("「」『』'\"")
    if compact in GENERIC_NEWGAME_ANSWERS or is_unconfirmed_value(text):
        return fallback
    return text


def story_short_clause(value: str, limit: int = 70) -> str:
    text = story_clean_answer(value)
    if not text:
        return ""
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip("、。/ ") + "…"


def story_fragment(value: str, limit: int = 70) -> str:
    return story_short_clause(value, limit).rstrip("。.!！?？")


def story_role_phrase(name: str, q1: str, profile_role: str = "") -> str:
    base = story_clean_answer(q1)
    role = ""
    if base:
        parsed = q1_components(base)
        if parsed["role"]:
            return f"{parsed['role']}・{name}" if name else parsed["role"]
        parts = [part.strip() for part in re.split(r"[、,/／。]+", base) if part.strip()]
        role_parts: list[str] = []
        for part in parts:
            clean = re.sub(r"\d{1,3}\s*歳", "", part).strip()
            if not clean or is_non_specific_literal(clean) or q1_name_is_omakase(clean):
                continue
            if name and (clean == name or clean.replace(" ", "") == name.replace(" ", "")):
                continue
            if any(word in clean for word in ["巨乳", "胸", "カップ", "色気", "エロ", "主人公にだけ"]):
                continue
            role_parts.append(clean)
        role = "、".join(role_parts[:2])
    if not role:
        role = story_clean_answer(profile_role, "日常の場にいる人")
    return f"{role}・{name}" if role else name


def story_inferred_wound(name: str, q1: str, q4: str) -> str:
    context = story_short_clause(q1, 48) or name
    gap = story_short_clause(q4, 58) or "表の顔と内側の温度差"
    return f"{context}として過ごす中で、{gap}を生んだ出来事がある。詳細は未確定: 進行で決める。"


