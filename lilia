LEAK_LITERAL_RE = re.compile(r"名前(?:とか)?まかせ|まかせる|おまかせ|お任せ|未指定")


def sanitize_omakase_literals(text: str) -> str:
    return LEAK_LITERAL_RE.sub("未確定: profile から推論", text)


def sanitize_generated_documents(documents: dict[str, str]) -> dict[str, str]:
    return {path: sanitize_omakase_literals(content) for path, content in documents.items()}


def generated_document_issues(
    documents: dict[str, str],
    answers: Optional[dict[int | str, str]] = None,
) -> list[dict[str, str]]:
    issues: list[dict[str, str]] = []
    answer_source = "\n".join(str(value) for value in (answers or {}).values())
    for path, content in documents.items():
        if path == "lilia/main/profile.md":
            continue
        if LEAK_LITERAL_RE.search(content):
            issues.append({"path": path, "kind": "omakase_literal", "literal": "omakase"})
        for literal in FORBIDDEN_GENERATED_LITERALS:
            if literal in content and not literal_supported_by_answers(literal, answer_source):
                issues.append({"path": path, "kind": "hardcoded_literal", "literal": literal})
    return issues


def literal_supported_by_answers(literal: str, answer_source: str) -> bool:
    if not answer_source:
        return False
    if literal in answer_source:
        return True
    variants = {literal}
    for suffix in ("前", "音", "の紐", "用の鋏"):
        if literal.endswith(suffix):
            variants.add(literal[: -len(suffix)])
    return any(variant and variant in answer_source for variant in variants)


def repair_generated_documents_with_placeholders(
    documents: dict[str, str],
    answers: Optional[dict[int | str, str]] = None,
) -> dict[str, str]:
    repaired = {path: sanitize_omakase_literals(content) for path, content in documents.items()}
    answer_source = "\n".join(str(value) for value in (answers or {}).values())
    for path, content in repaired.items():
        if path == "lilia/main/profile.md":
            continue
        updated = content
        for literal in FORBIDDEN_GENERATED_LITERALS:
            if not literal_supported_by_answers(literal, answer_source):
                updated = updated.replace(literal, PLACEHOLDER_PROFILE_VALUE)
        repaired[path] = updated
    return repaired


def issue_summary(issues: list[dict[str, str]]) -> str:
    if not issues:
        return "none"
    counts: dict[str, int] = {}
    for issue in issues:
        key = f"{issue['kind']}:{issue['literal']}"
        counts[key] = counts.get(key, 0) + 1
    return ",".join(f"{key}={count}" for key, count in sorted(counts.items()))


def validator_reinfer_documents(
    answers: dict[int | str, str],
    requested_engine: str,
    logger: Optional[OperationLogger] = None,
) -> tuple[Optional[dict[str, str]], Optional[str], str]:
    engine = choose_engine(requested_engine)
    if engine is None:
        if logger is not None:
            logger.write("validator_reinfer_unavailable", requested_engine=requested_engine)
        return None, None, f"{requested_engine} engine unavailable"
    instruction = (
        build_character_instruction_from_answers(answers)
        + "\n追加条件:\n"
        + "- おまかせ、未指定、名前まかせ等の入力語を出力本文へ残さない。\n"
        + "- Q&A、CharacterSheet、profileから推論できない具体物や場所は未確定として残す。\n"
        + "- 次の固定リテラルは使わない: "
        + "、".join(FORBIDDEN_GENERATED_LITERALS)
        + "\n"
    )
    try:
        from tools.character.core.master import generate_character

        character = generate_character(instruction, engine=engine)
        profile_engine = requested_engine if requested_engine == "auto" else engine
        docs, profile_meta = render_documents_from_character_yaml(character, answers, profile_engine)
        if logger is not None:
            logger.write("validator_reinfer_success", engine=engine, generated_files=list(docs))
            logger.write(
                "[profile] validation",
                status="pass" if profile_meta.get("validation_pass", True) else "failed",
                retry_count=profile_meta.get("retry_count", 0),
                sections_count=profile_meta.get("sections_count", 0),
            )
        return docs, engine, f"validator re-inferred via {engine}"
    except Exception as exc:
        if exc.__class__.__name__ == "ProfileGenerationError":
            raise
        if logger is not None:
            logger.write("validator_reinfer_failed", engine=engine, error=type(exc).__name__)
        return None, engine, f"{engine} validator re-inference failed: {exc}"


def validate_apply_newgame_documents(
    documents: dict[str, str],
    answers: dict[int | str, str],
    requested_engine: str,
    logger: Optional[OperationLogger] = None,
) -> tuple[dict[str, str], dict[str, object]]:
    initial_issues = generated_document_issues(documents, answers)
    result: dict[str, object] = {
        "initial_issues": len(initial_issues),
        "initial_summary": issue_summary(initial_issues),
        "repair_path": "none",
        "final_issues": 0,
        "final_summary": "none",
        "warning": "",
    }
    if logger is not None:
        logger.write("validator_initial", issues=len(initial_issues), summary=result["initial_summary"])
    if not initial_issues:
        return documents, result

    reinferred, engine, status = validator_reinfer_documents(answers, requested_engine, logger)
    result["reinference_engine"] = engine or ""
    result["reinference_status"] = status
    if reinferred is not None:
        reinferred_issues = generated_document_issues(reinferred, answers)
        if logger is not None:
            logger.write("validator_reinferred", issues=len(reinferred_issues), summary=issue_summary(reinferred_issues))
        if not reinferred_issues:
            result["repair_path"] = "ai_reinfer"
            return reinferred, result

    repaired = repair_generated_documents_with_placeholders(documents, answers)
    final_issues = generated_document_issues(repaired, answers)
    result["repair_path"] = "placeholder"
    result["final_issues"] = len(final_issues)
    result["final_summary"] = issue_summary(final_issues)
    if final_issues:
        result["warning"] = "validator placeholder repair left issues; inspect generated files"
    else:
        result["warning"] = "validator used placeholder repair"
    if logger is not None:
        logger.write(
            "validator_placeholder_repair",
            final_issues=len(final_issues),
            final_summary=result["final_summary"],
        )
    return repaired, result


