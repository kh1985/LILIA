def log_timestamp() -> str:
    return datetime.now(timezone.utc).astimezone().strftime("%Y%m%d_%H%M%S")


def safe_log_id(value: str) -> str:
    clean = re.sub(r"[^A-Za-z0-9_.-]+", "_", value.strip())
    return clean or "session"


def exception_caused_by(exc: BaseException, expected_type: type[BaseException]) -> bool:
    current: BaseException | None = exc
    while current is not None:
        if isinstance(current, expected_type):
            return True
        current = current.__cause__ or current.__context__
    return False


class OperationLogger:
    def __init__(self, operation: str, session_id: str):
        logs_dir = ROOT / "logs"
        logs_dir.mkdir(exist_ok=True)
        self.path = logs_dir / f"{operation}_{safe_log_id(session_id)}_{log_timestamp()}.log"
        self.write("start", operation=operation, session=session_id)

    def write(self, event: str, **fields: object) -> None:
        parts = [datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"), event]
        for key, value in fields.items():
            if isinstance(value, (list, tuple, set)):
                rendered = ",".join(str(item) for item in value)
            else:
                rendered = str(value)
            rendered = rendered.replace("\n", " / ")
            parts.append(f"{key}={rendered}")
        with self.path.open("a", encoding="utf-8") as handle:
            handle.write(" | ".join(parts) + "\n")
            handle.flush()
            os.fsync(handle.fileno())

    def section(self, title: str) -> None:
        with self.path.open("a", encoding="utf-8") as handle:
            handle.write(f"\n=== {title} ===\n")
            handle.flush()
            os.fsync(handle.fileno())


def ensure_autosave(data: dict) -> dict:
    autosave = data.get("autosave")
    if not isinstance(autosave, dict):
        autosave = {}
        data["autosave"] = autosave
    for key, value in AUTOSAVE_DEFAULTS.items():
        autosave.setdefault(key, value)
    return autosave


def mark_first_scene_started_if_needed(data: dict) -> bool:
    initialization = data.get("initialization")
    if not isinstance(initialization, dict):
        return False

    if data.get("current_phase") != "first_scene_ready":
        return False
    if initialization.get("first_scene_status") != "ready":
        return False

    data["current_phase"] = "active"
    initialization["first_scene_status"] = "started"
    return True


def is_placeholder_lilia_name(value: object) -> bool:
    if not isinstance(value, str):
        return True
    compact = re.sub(r"\s+", "", value).strip("「」『』'\"")
    if not compact:
        return True
    lowered = compact.lower()
    return (
        lowered
        in {
            "lilia",
            "リリア",
            "未設定",
            "未定",
            "なし",
            "特になし",
            "おまかせ",
            "作中名未確定",
            "初対面",
            "顔見知り",
            "知っている",
            "知っているけど",
            "深くは知らない",
        }
        or lowered.startswith("lilia（仮")
        or lowered.startswith("lilia(仮")
        or lowered.startswith("リリア（仮")
        or lowered.startswith("リリア(仮")
    )


def clean_lilia_name(value: object) -> str:
    if not isinstance(value, str):
        return ""
    name = value.strip().strip("「」『』'\"")
    name = re.split(r"\s+#", name, maxsplit=1)[0].strip()
    return "" if is_placeholder_lilia_name(name) else name


def extract_profile_name(profile: str) -> str:
    for line in profile.splitlines():
        match = re.match(r"^name:\s*(.+?)\s*$", line)
        if match:
            return clean_lilia_name(match.group(1))
    return ""


OMAKASE_LITERAL_VALUES = {
    "まかせる",
    "おまかせ",
    "お任せ",
    "任せる",
    "任せます",
    "未指定",
}
OMAKASE_LITERALS = OMAKASE_LITERAL_VALUES

NON_SPECIFIC_VALUES = OMAKASE_LITERAL_VALUES | {
    "特になし",
    "なし",
    "未設定",
    "未確定",
    "SOURCE_FALLBACK",
}


def compact_text(value: str) -> str:
    return re.sub(r"\s+", "", (value or "").strip()).strip("「」『』'\"")


def is_omakase_literal(value: str) -> bool:
    return compact_text(value) in OMAKASE_LITERAL_VALUES


def is_non_specific_literal(value: str) -> bool:
    compact = compact_text(value)
    return compact in NON_SPECIFIC_VALUES or compact == compact_text(UNCONFIRMED)


def q1_name_is_omakase(value: str) -> bool:
    compact = compact_text(value)
    return bool(compact and "名前" in compact and any(word in compact for word in ["まかせ", "おまかせ", "お任せ", "任せ"]))


def q1_components(value: str) -> dict[str, str]:
    text = re.sub(r"\s+", " ", (value or "").replace("\n", " / ")).strip()
    parts = [part.strip() for part in re.split(r"[、,/／。]+", text) if part.strip()]
    result = {"name": "", "age": "", "role": "", "appearance": "", "personality": ""}
    appearance_words = ["巨乳", "胸", "カップ", "色気", "エロ", "髪", "目", "視線", "香", "服", "身体", "スタイル"]
    personality_words = ["主人公にだけ", "だけ", "クール", "明る", "暗", "甘", "厳", "優", "無口", "強気", "弱気", "穏やか", "博識", "本心", "隠", "テキパキ", "気だる", "毒舌", "線引き", "朗らか", "頼", "苦手"]
    role_words = ["店", "店主", "店員", "職", "勤務", "会社", "学生", "教師", "医師", "エンジニア", "作家", "役"]
    appearance: list[str] = []
    personality: list[str] = []
    role: list[str] = []
    for part in parts:
        clean = part.strip()
        if not clean or is_non_specific_literal(clean) or q1_name_is_omakase(clean):
            continue
        age_match = re.search(r"(\d{1,3}\s*歳)", clean)
        if age_match and not result["age"]:
            result["age"] = age_match.group(1).replace(" ", "")
            clean = clean.replace(age_match.group(0), "").strip()
            if not clean:
                continue
        if any(word in clean for word in appearance_words):
            appearance.append(clean)
            continue
        if any(word in clean for word in personality_words):
            personality.append(clean)
            continue
        if any(word in clean for word in role_words):
            role.append(clean)
            continue
        if not result["name"] and len(clean) <= 12 and not any(char.isdigit() for char in clean):
            result["name"] = clean
        else:
            role.append(clean)
    result["appearance"] = "、".join(appearance)
    result["personality"] = "、".join(personality)
    result["role"] = "、".join(role)
    return result


def answer_has_value(answers: dict[int | str, str], number: int) -> bool:
    return bool(str(answers.get(number, "")).strip())


def is_wave101_answers(answers: dict[int | str, str]) -> bool:
    return str(answers.get("format") or "") == "wave101_q1_q9" or answer_has_value(answers, 9)


def is_wave10_answers(answers: dict[int | str, str]) -> bool:
    return str(answers.get("format") or "") == "wave10_q1_q6" or (
        not is_wave101_answers(answers)
        and not answer_has_value(answers, 7)
        and not answer_has_value(answers, 8)
    )


def is_wave7_answers(answers: dict[int | str, str]) -> bool:
    return not is_wave101_answers(answers) and not is_wave10_answers(answers)


def qa_basic(answers: dict[int | str, str]) -> str:
    return answer(answers, 1)


def qa_visual(answers: dict[int | str, str]) -> str:
    return answer(answers, 2 if not is_wave7_answers(answers) else 3)


def qa_freeform(answers: dict[int | str, str]) -> str:
    return answer(answers, 3) if is_wave10_answers(answers) else ""


def qa_anchor(answers: dict[int | str, str]) -> str:
    if is_wave101_answers(answers):
        return answer(answers, 3)
    if is_wave10_answers(answers):
        return qa_freeform(answers)
    return answer(answers, 3)


def qa_encounter(answers: dict[int | str, str]) -> str:
    if is_wave101_answers(answers):
        return answer(answers, 6)
    return answer(answers, 4 if is_wave10_answers(answers) else 2)


def qa_gap(answers: dict[int | str, str]) -> str:
    if is_wave101_answers(answers):
        return answer(answers, 4)
    if is_wave10_answers(answers):
        freeform = qa_freeform(answers)
        return "" if is_non_specific_literal(freeform) else freeform
    return answer(answers, 4)


def qa_wound(answers: dict[int | str, str]) -> str:
    if is_wave101_answers(answers):
        return answer(answers, 5)
    return qa_freeform(answers) if is_wave10_answers(answers) else answer(answers, 5)


def qa_calling(answers: dict[int | str, str]) -> str:
    return answer(answers, 7 if is_wave101_answers(answers) else 6)


def qa_protagonist(answers: dict[int | str, str]) -> str:
    if is_wave101_answers(answers):
        return answer(answers, 8)
    return answer(answers, 5 if is_wave10_answers(answers) else 7)


def extract_avoid_from_freeform(text: str) -> str:
    if is_non_specific_literal(text):
        return ""
    lines = [line.strip("- ・\t ") for line in (text or "").splitlines() if line.strip()]
    joined = " / ".join(lines) if lines else text
    candidates = []
    for part in re.split(r"[。/／\n;；]+", joined):
        clean = part.strip()
        if not clean:
            continue
        if any(word in clean for word in ["避け", "苦手", "NG", "禁止", "出さない", "なしにして", "控え"]):
            candidates.append(clean)
    return " / ".join(candidates)


def qa_constraints(answers: dict[int | str, str]) -> str:
    if is_wave101_answers(answers):
        return answer(answers, 9)
    if is_wave10_answers(answers):
        return extract_avoid_from_freeform(qa_freeform(answers))
    return answer(answers, 8)


def qa_visual_or_anchor(answers: dict[int | str, str]) -> str:
    for value in [qa_anchor(answers), qa_visual(answers)]:
        if value and not is_non_specific_literal(value):
            return value
    return ""


HAIR_COLOR_PATTERNS = [
    (r"黒髪|黒い髪|黒の髪|黒", "黒"),
    (r"茶髪|茶色の髪|茶色|ブラウン", "茶"),
    (r"栗色の髪|栗色", "栗色"),
    (r"金髪|金色の髪|ブロンド|金", "金"),
    (r"銀髪|銀色の髪|銀", "銀"),
    (r"白髪|白い髪|白", "白"),
    (r"赤髪|赤い髪|赤", "赤"),
    (r"青髪|青い髪|青", "青"),
    (r"緑髪|緑の髪|緑", "緑"),
    (r"灰色の髪|灰髪|グレー|灰", "灰"),
]


def split_hair_part(part: str) -> tuple[str, str]:
    color = ""
    style = part.strip()
    for pattern, label in HAIR_COLOR_PATTERNS:
        if re.search(pattern, style):
            color = label
            style = re.sub(pattern, "", style, count=1)
            break
    style = re.sub(r"^(?:髪型|髪色|髪|の)+", "", style)
    style = re.sub(r"(?:髪|ヘア)$", "", style).strip(" の、,/／")
    return style, color


def visual_components(value: str) -> dict[str, str]:
    text = re.sub(r"\s+", " ", (value or "").replace("\n", " / ")).strip()
    parts = [part.strip() for part in re.split(r"[、,/／。]+", text) if part.strip()]
    result = {"hair_style": "", "hair_color": "", "eye_color": "", "body": "", "outfit": "", "notes": ""}
    note_parts: list[str] = []
    for part in parts:
        compact = compact_text(part)
        if not compact or is_non_specific_literal(part):
            continue
        if any(word in part for word in ["髪", "ボブ", "ロング", "ショート", "ウェーブ", "前髪", "ヘア"]):
            style, color = split_hair_part(part)
            if color:
                result["hair_color"] = result["hair_color"] or color
            if style:
                if result["hair_style"] and style not in result["hair_style"]:
                    result["hair_style"] = f"{result['hair_style']}、{style}"
                else:
                    result["hair_style"] = result["hair_style"] or style
        elif any(word in part for word in ["目", "眼", "瞳"]):
            result["eye_color"] = result["eye_color"] or part
        elif any(word in part for word in ["細身", "小柄", "長身", "巨乳", "体型", "中肉", "がっしり", "曲線"]):
            result["body"] = result["body"] or part
        elif any(word in part for word in ["服", "シャツ", "スカート", "ニット", "タートルネック", "スラックス", "パーカー", "ジャケット", "コート", "靴", "外套"]):
            result["outfit"] = result["outfit"] or part
        else:
            note_parts.append(part)
    result["notes"] = " / ".join(note_parts) or text
    return result


def split_gap_answer(value: str) -> tuple[str, str, str]:
    clean = (value or "").replace("\n", " / ").strip()
    if not clean or is_non_specific_literal(clean):
        return "", "", ""
    outward = ""
    inward = ""
    patterns = [
        (r"表(?:は|では)?(.+?)(?:内側|内|裏|一人(?:の時)?)(?:は|では)?(.+)", "表", "内"),
        (r"(?:人前|他人の前)(?:は|では)?(.+?)(?:一人(?:の時)?|内側|裏)(?:は|では)?(.+)", "人前", "一人"),
    ]
    for pattern, _, _ in patterns:
        match = re.search(pattern, clean)
        if match:
            outward = match.group(1).strip(" 、。/／")
            inward = match.group(2).strip(" 、。/／")
            break
    if not outward or not inward:
        parts = [part.strip() for part in re.split(r"[。/／;；]+", clean) if part.strip()]
        if len(parts) >= 2:
            outward, inward = parts[0], parts[1]
    contradiction = clean
    if outward and inward:
        contradiction = f"{outward} / {inward}"
    return outward, inward, contradiction


