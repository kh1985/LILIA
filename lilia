    final = _ensure_default_flag(final, "--engine", "auto")
    final = _ensure_judge_default(final)
    command_ai_playtest(final)


def parse_dev_smoke_options(args: list[str]) -> tuple[list[str], int, str, bool]:
    """Parse dev-smoke flags. Returns ``(positional, turns, engine, judge)``."""

    turns = 3
    engine = "auto"
    judge = True
    judge_seen = False
    no_judge_seen = False
    cleaned: list[str] = []
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--turns":
            index += 1
            if index >= len(args):
                die("--turns requires a value")
            try:
                turns = int(args[index])
            except ValueError:
                die("--turns must be a positive integer")
        elif arg.startswith("--turns="):
            try:
                turns = int(arg.split("=", 1)[1])
            except ValueError:
                die("--turns must be a positive integer")
        elif arg == "--engine":
            index += 1
            if index >= len(args):
                die("--engine requires codex, claude, or auto")
            engine = args[index]
        elif arg.startswith("--engine="):
            engine = arg.split("=", 1)[1]
        elif arg == "--no-judge":
            no_judge_seen = True
            judge = False
        elif arg == "--judge":
            judge_seen = True
            judge = True
        else:
            cleaned.append(arg)
        index += 1
    if turns < 1:
        die("--turns must be a positive integer")
    if judge_seen and no_judge_seen:
        die("choose either --judge or --no-judge, not both")
    if engine not in {"auto", "codex", "claude"}:
        die("--engine must be codex, claude, or auto")
    return cleaned, turns, engine, judge


def command_dev_smoke(args: list[str]) -> None:
    cleaned, turns, requested_engine, judge = parse_dev_smoke_options(args)
    if len(cleaned) != 1:
        die("dev-smoke requires <session_name>")
    src_session = resolve_session(cleaned[0])
    engine = resolve_engine(requested_engine)
    if engine is None:
        die(
            "no AI CLI found for dev-smoke. install codex or claude, "
            f"or pass --engine codex|claude (requested: {requested_engine})."
        )

    results: list[tuple[str, Optional[Path]]] = []
    for persona in ("normal", "passive", "boundary"):
        print()
        print(f"=== dev-smoke: persona={persona} turns={turns} engine={engine} ===")
        try:
            run_dir = run_ai_playtest_session(
                src_session=src_session,
                persona=persona,
                turns=turns,
                requested_engine=requested_engine,
                engine=engine,
                verbose=False,
                quiet=False,
                judge=judge,
            )
        except SystemExit as exc:
            print(f"persona={persona} の実行が失敗しました (exit={exc.code}).")
            results.append((persona, None))
            continue
        results.append((persona, run_dir))

    print()
    print("Smoke完了:")
    for persona, run_dir in results:
        if run_dir is None:
            print(f"- {persona}:   FAILED")
        else:
            print(f"- {persona}:   {run_dir.relative_to(ROOT)}")


