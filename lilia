def parse_dev_clean_options(args: list[str]) -> tuple[int, bool]:
    days = 7
    yes = False
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--days":
            index += 1
            if index >= len(args):
                die("--days requires a value")
            try:
                days = int(args[index])
            except ValueError:
                die("--days must be a non-negative integer")
        elif arg.startswith("--days="):
            try:
                days = int(arg.split("=", 1)[1])
            except ValueError:
                die("--days must be a non-negative integer")
        elif arg == "--yes":
            yes = True
        elif arg == "--dry-run":
            yes = False
        else:
            die(f"unknown dev-clean-runs option: {arg}")
        index += 1
    if days < 0:
        die("--days must be a non-negative integer")
    return days, yes


