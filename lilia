    return {
        key: "\n".join(lines).strip()
        for key, lines in sections.items()
        if "\n".join(lines).strip()
    }


def parse_bracket_list(value: str) -> list[str]:
    clean = value.strip()
    if clean.startswith("[") and clean.endswith("]"):
        clean = clean[1:-1]
    clean = clean.replace("、", ",").replace("，", ",")
    return [item.strip().strip("'\"") for item in clean.split(",") if item.strip()]


def normalize_knowledge_field(label: str) -> str:
    key = label.strip().lower().replace(" ", "_").replace("-", "_")
    mapping = {
        "開示経路": "notes",
        "知った主体": "known_to",
        "知っている主体": "known_to",
        "主体": "known_to",
        "source": "source",
        "value": "value",
        "fictional_status": "fictional_status",
        "status": "fictional_status",
        "known_to": "known_to",
        "known": "known_to",
        "acquired_at": "acquired_at",
        "weight": "weight",
        "notes": "notes",
        "note": "notes",
    }
    return mapping.get(label.strip(), mapping.get(key, key))


def parse_knowledge_update(body: str) -> list[dict[str, object]]:
    updates: list[dict[str, object]] = []
    current_mode = ""
    current: Optional[dict[str, object]] = None
    for raw_line in body.splitlines():
        line = raw_line.rstrip()
        heading = re.match(r"^###\s+(.+?)\s*$", line)
        if heading:
            current_mode = heading.group(1).strip()
            current = None
            continue

        bullet = re.match(r"^-\s+([A-Za-z0-9_.-]+)(?::\s*(.+))?\s*$", line)
        if bullet:
            key = bullet.group(1).strip()
            rest = (bullet.group(2) or "").strip()
            mode = "promotion" if "→" in rest or "->" in rest else "new"
            if "昇格" in current_mode:
                mode = "promotion"
            elif "新規" in current_mode:
                mode = "new"
            current = {"mode": mode, "key": key, "fields": {}}
            if rest:
                match = re.search(r"(?:→|->)\s*([A-Za-z_-]+)", rest)
                if match:
                    current["new_status"] = match.group(1)
            updates.append(current)
            continue

        field_match = re.match(r"^\s+-\s*([^:：]+)[:：]\s*(.+?)\s*$", line)
        if field_match and current is not None:
            field = normalize_knowledge_field(field_match.group(1))
            value = field_match.group(2).strip()
            fields = current.setdefault("fields", {})
            if isinstance(fields, dict):
                fields[field] = value

    return updates


def find_knowledge_item_span(lines: list[str], key: str) -> tuple[int, int] | None:
    key_re = re.compile(rf"^(\s*)-\s+key:\s*{re.escape(key)}\s*$")
    for index, line in enumerate(lines):
        match = key_re.match(line)
        if not match:
            continue
        indent = match.group(1)
        end = len(lines)
        next_item_re = re.compile(rf"^{re.escape(indent)}-\s+key:\s+")
        for cursor in range(index + 1, len(lines)):
            if next_item_re.match(lines[cursor]):
                end = cursor
                break
            if lines[cursor].strip() == "```":
                end = cursor
                break
        return index, end
    return None


def set_knowledge_item_field(lines: list[str], start: int, end: int, field: str, value: str) -> tuple[int, int]:
    field_re = re.compile(rf"^(\s*){re.escape(field)}:\s*")
    formatted = value
    if field in {"value", "notes"}:
        formatted = yaml_scalar(value)
    elif field == "known_to":
        formatted = yaml_list(parse_bracket_list(value))
    for index in range(start + 1, end):
        if field_re.match(lines[index]):
            indent = field_re.match(lines[index]).group(1)  # type: ignore[union-attr]
            lines[index] = f"{indent}{field}: {formatted}"
            return start, end
    insert_at = end
    lines.insert(insert_at, f"    {field}: {formatted}")
    return start, end + 1


def merge_knowledge_known_to(lines: list[str], start: int, end: int, additions: list[str]) -> tuple[int, int]:
    known_re = re.compile(r"^(\s*)known_to:\s*\[(.*?)\]\s*$")
    for index in range(start + 1, end):
        match = known_re.match(lines[index])
        if not match:
            continue
        existing = parse_bracket_list(match.group(2))
        merged = existing[:]
        for value in additions:
            if value and value not in merged:
                merged.append(value)
        lines[index] = f"{match.group(1)}known_to: {yaml_list(merged)}"
        return start, end
    return set_knowledge_item_field(lines, start, end, "known_to", yaml_list(additions))


def knowledge_insert_index(lines: list[str]) -> int:
    for index, line in enumerate(lines):
        if line.strip() == "```" and any(prev.strip() == "items:" for prev in lines[:index]):
            return index
    return len(lines)


def merge_knowledge_state_content(content: str, update_body: str) -> str:
    lines = content.rstrip().splitlines()
    updates = parse_knowledge_update(update_body)
    for update in updates:
        key = str(update.get("key") or "").strip()
        if not key:
            continue
        fields = update.get("fields")
        field_map = fields if isinstance(fields, dict) else {}
        span = find_knowledge_item_span(lines, key)
        if update.get("mode") == "promotion" and span is not None:
            start, end = span
            new_status = str(update.get("new_status") or field_map.get("fictional_status") or "").strip()
            if new_status:
                start, end = set_knowledge_item_field(lines, start, end, "fictional_status", new_status)
            acquired_at = str(field_map.get("acquired_at") or "").strip()
            if acquired_at:
                start, end = set_knowledge_item_field(lines, start, end, "acquired_at", acquired_at)
            weight = str(field_map.get("weight") or "").strip()
            if weight:
                start, end = set_knowledge_item_field(lines, start, end, "weight", weight)
            notes = str(field_map.get("notes") or "").strip()
            if notes:
                start, end = set_knowledge_item_field(lines, start, end, "notes", notes)
            known_to = str(field_map.get("known_to") or "").strip()
            if known_to:
                start, end = merge_knowledge_known_to(lines, start, end, parse_bracket_list(known_to))
            continue

        if update.get("mode") == "promotion" and span is None:
            status = str(update.get("new_status") or field_map.get("fictional_status") or "shared")
            item = knowledge_item_yaml(
                key=key,
                value=str(field_map.get("value") or "未確定"),
                fictional_status=status,
                source=str(field_map.get("source") or "inferred"),
                known_to=parse_bracket_list(str(field_map.get("known_to") or "GM")),
                acquired_at=str(field_map.get("acquired_at") or "未確定"),
                weight=str(field_map.get("weight") or "medium"),
                notes=str(field_map.get("notes") or "turn_update.md から追加"),
            )
            insert_at = knowledge_insert_index(lines)
            lines[insert_at:insert_at] = item + [""]
            continue

        if update.get("mode") == "new":
            if span is not None:
                start, end = span
                for field in ["value", "fictional_status", "source", "acquired_at", "weight", "notes"]:
                    value = str(field_map.get(field) or "").strip()
                    if value:
                        start, end = set_knowledge_item_field(lines, start, end, field, value)
                known_to = str(field_map.get("known_to") or "").strip()
                if known_to:
                    start, end = merge_knowledge_known_to(lines, start, end, parse_bracket_list(known_to))
                continue
            item = knowledge_item_yaml(
                key=key,
                value=str(field_map.get("value") or "未確定"),
                fictional_status=str(field_map.get("fictional_status") or "shared"),
                source=str(field_map.get("source") or "inferred"),
                known_to=parse_bracket_list(str(field_map.get("known_to") or "GM")),
                acquired_at=str(field_map.get("acquired_at") or "未確定"),
                weight=str(field_map.get("weight") or "medium"),
                notes=str(field_map.get("notes") or ""),
            )
            insert_at = knowledge_insert_index(lines)
            lines[insert_at:insert_at] = item + [""]

    return "\n".join(lines).rstrip() + "\n"


def answer(answers: dict[int | str, str], number: int | str) -> str:
