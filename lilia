def _read_input(prompt: str) -> str:
    """Read a single line from stdin, prompting once. Returns '' on EOF."""

    try:
        return input(prompt)
    except EOFError:
        return ""


def _extract_report_summary(report_path: Path) -> str:
    """Pull just the '## Summary' section out of a judge report."""

    try:
        text = report_path.read_text(encoding="utf-8")
    except OSError as exc:
        return f"(report読み込み失敗: {exc})"
    lines = text.splitlines()
    in_summary = False
    out: list[str] = []
    for line in lines:
        if line.startswith("## Summary"):
            in_summary = True
            out.append(line)
            continue
        if in_summary:
            if line.startswith("## "):
                break
            out.append(line)
    return "\n".join(out).rstrip() or "(Summary section not found)"


def _show_session_picker(prompt: str = "セッション > ") -> Optional[Path]:
    sessions = session_candidates()
    if not sessions:
        print("saves/ にセッションがありません。")
        return None
    print()
    print("利用可能なセッション:")
    for idx, path in enumerate(sessions, start=1):
        data = read_session_json(path)
        phase = data.get("apply_newgame_phase", "-")
        print(f"  {idx}. {path.name}  (phase={phase})")
    raw = _read_input(prompt).strip()
    if not raw:
        print("キャンセルしました。")
        return None
    if raw.isdigit():
        idx = int(raw) - 1
        if 0 <= idx < len(sessions):
            return sessions[idx]
        print(f"範囲外の番号です: {raw}")
        return None
    for path in sessions:
        if path.name == raw:
            return path
    print(f"そのセッションは見つかりません: {raw}")
    return None


def _menu_run_one(
    *,
    src_session: Path,
    persona: str,
    turns: int,
    requested_engine: str,
    judge: bool,
) -> Optional[Path]:
    """Resolve engine + run one ai-playtest. Returns run_dir or None on failure.

    Catches ``SystemExit`` so the menu loop survives engine-level failures.
