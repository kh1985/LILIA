def turn_update_review_text(value: object) -> str:
    text = re.sub(r"\s+", " ", str(value or "")).strip()
    if text.startswith("#"):
        text = "review: " + text.lstrip("#").strip()
    return text


def checkpoint_state_text(value: object) -> str:
    text = turn_update_review_text(value)
    text = re.sub(
        r"\b(?:closure_candidate|story_completion_status|checkpoint_only|recommended_next_arc_candidate|next_arc_candidate)\b",
        "",
        text,
        flags=re.IGNORECASE,
    )
    text = re.sub(r"\bTurn\s*\d+\s*で[^。/／]*[。/／]?", "", text)
    text = re.sub(r"\bJudge detected\b[^。/／]*[。/／]?", "", text, flags=re.IGNORECASE)
    text = text.replace("closure入口:", "").replace("closure入口：", "")
    text = text.replace("closure candidate", "").replace("Closure Candidate", "")
    text = text.replace("story completion", "").replace("Story Completion", "")
    text = re.sub(
        r"\breview:\s*(?:scene|event_card|hotset|memory|relationship|beliefs|story_deck|hook_updates)\b\s*-?\s*",
        "",
        text,
        flags=re.IGNORECASE,
    )
    text = re.sub(r"\breview:\s*", "", text, flags=re.IGNORECASE)
    text = re.sub(r"\s+", " ", text).strip(" -/／、。")
    return text


def checkpoint_sentence(value: object, fallback: str) -> str:
    text = checkpoint_state_text(value) or fallback
    if not text.endswith(("。", "！", "？", ".", "!", "?")):
        text = f"{text}。"
    return text


def render_ai_playtest_closure_candidate_note(candidate: dict[str, object]) -> str:
    turns = ", ".join(str(item) for item in candidate.get("closure_candidate_turns", [])) or "-"
    hook_type = turn_update_review_text(candidate.get("possible_next_hook_type", "")) or "-"
    return "\n".join(
        [
            f"- closure_candidate_turns: {turns}",
            f"- possible_next_hook_type: {hook_type}",
            f"- possible_next_question: {turn_update_review_text(candidate.get('possible_next_question', ''))}",
            f"- reason: {turn_update_review_text(candidate.get('reason', ''))}",
            f"- risk_if_continued: {turn_update_review_text(candidate.get('risk_if_continued', ''))}",
            f"- recommended_closure_action: {turn_update_review_text(candidate.get('recommended_closure_action', ''))}",
        ]
    )


def render_ai_playtest_story_completion_note(candidate: dict[str, object]) -> str:
    hook_type = turn_update_review_text(candidate.get("suggested_active_hook_type", "")) or "-"
    return "\n".join(
        [
            f"- story_completion_status: {turn_update_review_text(candidate.get('story_completion_status', ''))}",
            f"- suggested_active_hook_type: {hook_type}",
            f"- suggested_story_function: {turn_update_review_text(candidate.get('suggested_story_function', ''))}",
            f"- recommended_next_arc_candidate: {turn_update_review_text(candidate.get('recommended_next_arc_candidate', ''))}",
            f"- reason: {turn_update_review_text(candidate.get('reason', ''))}",
            f"- should_apply_now: {str(candidate.get('should_apply_now', False)).lower()}",
            f"- checkpoint_only: {str(candidate.get('checkpoint_only', True)).lower()}",
        ]
    )


def closure_candidate_slug(candidate: dict[str, object]) -> str:
    hook_type = str(candidate.get("possible_next_hook_type", "hook") or "hook")
    turns = "_".join(str(item) for item in candidate.get("closure_candidate_turns", []))
    slug = re.sub(r"[^A-Za-z0-9_]+", "_", f"handoff_{hook_type}_{turns}").strip("_")
    return slug or "handoff_candidate"


def render_ai_playtest_closure_turn_update_sections(
    candidate: dict[str, object],
    *,
    story_completion: Optional[dict[str, object]] = None,
) -> list[str]:
    story_hook_type = checkpoint_state_text(
        story_completion.get("suggested_active_hook_type", "") if story_completion else ""
    )
    hook_type = story_hook_type or checkpoint_state_text(candidate.get("possible_next_hook_type", ""))
    next_question = checkpoint_state_text(candidate.get("possible_next_question", ""))
    next_arc = checkpoint_state_text(
        story_completion.get("recommended_next_arc_candidate", "") if story_completion else ""
    )
    story_function = checkpoint_state_text(
        story_completion.get("suggested_story_function", "") if story_completion else ""
    )
    story_reason = checkpoint_state_text(story_completion.get("reason", "") if story_completion else "")
    reason = checkpoint_state_text(candidate.get("reason", ""))
    risk = checkpoint_state_text(candidate.get("risk_if_continued", ""))
    candidate_id = closure_candidate_slug(candidate)
    next_hook_body = checkpoint_sentence(
        next_arc or next_question or reason,
        "次sceneへ渡す入口を人間が確認する。",
    )
    visible_entry = checkpoint_sentence(next_arc or next_question, next_hook_body)
    reason_text = checkpoint_sentence(story_reason or reason, "一度場面が閉じ、次の確認へ移れる状態になった。")
    risk_text = checkpoint_sentence(risk, "同じ余韻を続けると場面進行が弱くなる。")

    lines = [
        "## next_hook",
        "",
        next_hook_body,
        "",
        "## hook_updates",
        "",
        f"- candidate_id: {candidate_id}",
        f"- hook_type: {hook_type or 'main'}",
        "- update_target: candidate",
        f"- status: pending",
        f"- function_candidate: {story_function or 'next_scene_handoff'}",
        f"- visible_entry: {visible_entry}",
        "- promotion_condition: 人間が直近のやりとりを確認し、scene / event_card / hotset が同じ入口へ揃う時だけactive stateへ昇格する。",
        "- grounding_guard: Candidateのままではactive eventとして使わない。保存にない具体手がかりを足さない。",
        f"- reason: {reason_text}",
        f"- risk_if_continued: {risk_text}",
    ]
    return lines


def collect_apply_turn_dry_run_result(session_path: Path, update_path: Path) -> dict[str, object]:
    timestamp = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    sections = parse_turn_update(update_path)
    if not sections:
        return {
            "status": "FAIL",
            "timestamp": timestamp,
            "error": "turn_update.md has no non-empty supported sections",
            "sections": [],
            "updated": [],
            "skipped": [],
            "warnings": [],
            "apply_turn_executed": False,
        }

    updated: list[str] = []
    skipped: list[str] = []
    warnings: list[str] = []

    def mark_updated(rel_path: str) -> None:
        if rel_path not in updated:
            updated.append(rel_path)

    def mark_skipped(message: str) -> None:
        if message not in skipped:
            skipped.append(message)

    try:
        fingerprint = turn_update_fingerprint(sections)
        session_data = read_session_json(session_path)
        duplicate = find_applied_turn_update(session_data, fingerprint)
        if duplicate is not None:
            warnings.append(duplicate_turn_update_message(duplicate, fingerprint))

        for key, body in sections.items():
            if key == "hook_updates":
                for rel_path in apply_hook_updates(session_path, body, timestamp, True):
                    mark_updated(rel_path)
                continue
            if key == "next_hook":
                promoted_paths = [
                    rel_path
                    for rel_path, section_key in [
                        ("current/scene.md", "scene"),
                        ("current/event_card.md", "event_card"),
                        ("current/hotset.md", "hotset"),
                    ]
                    if section_key not in sections
                ]
                for rel_path in promoted_paths:
                    mark_updated(rel_path)
                mark_updated("current/event_card.md")
                mark_updated("story/story_deck.md")
                continue
            rel_path = TURN_UPDATE_TARGETS[key]
            if key == "knowledge_state" and not (session_path / rel_path).exists():
                mark_skipped(f"{rel_path} missing; skipped knowledge_state merge for legacy session")
                continue
            mark_updated(rel_path)
    except Exception as exc:
        return {
            "status": "FAIL",
            "timestamp": timestamp,
            "error": f"{type(exc).__name__}: {exc}",
            "sections": list(sections),
            "updated": updated,
            "skipped": skipped,
            "warnings": warnings,
            "apply_turn_executed": False,
        }

    return {
        "status": "WARN" if warnings else "PASS",
        "timestamp": timestamp,
        "error": "",
        "sections": list(sections),
        "updated": updated,
        "skipped": skipped,
        "warnings": warnings,
        "apply_turn_executed": False,
    }


def render_apply_turn_dry_run_result(result: dict[str, object], update_path: Path, session_path: Path) -> str:
    lines = [
        "# AI Playtest Apply-Turn Dry Run",
        "",
        f"- dry_run_result: {result.get('status', 'FAIL')}",
        "- dry_run: true",
        "- apply_turn_executed: false",
        f"- session: {relative_to_root_text(session_path)}",
        f"- turn_update_candidate: {relative_to_root_text(update_path)}",
        f"- timestamp: {result.get('timestamp', '')}",
        "",
        "## Sections",
        "",
    ]
    sections = result.get("sections", [])
    if isinstance(sections, list) and sections:
        lines.extend(f"- {section}" for section in sections)
    else:
        lines.append("- none")
    lines.extend(["", "## Would Update", ""])
    updated = result.get("updated", [])
    if isinstance(updated, list) and updated:
        lines.extend(f"- {rel_path}" for rel_path in updated)
    else:
        lines.append("- none")
    skipped = result.get("skipped", [])
    if isinstance(skipped, list) and skipped:
        lines.extend(["", "## Skipped", ""])
        lines.extend(f"- {message}" for message in skipped)
    warnings = result.get("warnings", [])
    if isinstance(warnings, list) and warnings:
        lines.extend(["", "## Warnings", ""])
        lines.extend(f"- {message}" for message in warnings)
    error = str(result.get("error", "") or "")
    if error:
        lines.extend(["", "## Error", "", error])
    lines.extend(
        [
            "",
            "## Boundary",
            "",
            "- This dry-run does not reset autosave counters.",
            "- This dry-run does not write memory / relationship / beliefs / event_card / hook state.",
            "- A human must inspect and replace the candidate before any real apply-turn.",
        ]
    )
    return "\n".join(lines).rstrip() + "\n"


def render_ai_playtest_checkpoint_summary(
    *,
    turn: int,
    tick: dict[str, int | bool],
    checkpoint_mode: str,
    candidate_path: Optional[Path],
    dry_run_path: Optional[Path],
    dry_run_result: Optional[dict[str, object]],
    closure_candidate: Optional[dict[str, object]] = None,
    story_completion: Optional[dict[str, object]] = None,
) -> str:
    dry_status = "not_run" if dry_run_result is None else str(dry_run_result.get("status", "FAIL"))
    hook_updates_included = False
    next_hook_candidate_path = ""
    if candidate_path is not None and candidate_path.exists():
        candidate_text = candidate_path.read_text(encoding="utf-8")
        hook_updates_included = "## hook_updates" in candidate_text
        if "## next_hook" in candidate_text:
            next_hook_candidate_path = relative_to_root_text(candidate_path)
    next_arc_candidate_path = relative_to_root_text(candidate_path) if story_completion is not None and candidate_path is not None else ""
    lines = [
        "# AI Playtest Checkpoint Summary",
        "",
        f"- checkpoint_turn: {turn}",
        f"- scene_tick: {tick['display_turn']}/{tick['interval_turns']}",
        f"- autosave_required: {str(tick['autosave_required']).lower()}",
        f"- checkpoint_mode: {checkpoint_mode}",
        f"- apply_turn_executed: false",
        f"- closure_candidate_used: {str(closure_candidate is not None).lower()}",
        f"- story_completion_used: {str(story_completion is not None).lower()}",
        f"- next_hook_candidate_path: {next_hook_candidate_path or '-'}",
        f"- next_arc_candidate_path: {next_arc_candidate_path or '-'}",
        f"- hook_updates_candidate_included: {str(hook_updates_included).lower()}",
        f"- dry_run_result: {dry_status}",
    ]
    if story_completion is not None:
        lines.extend(
            [
                f"- story_completion_status: {turn_update_review_text(story_completion.get('story_completion_status', ''))}",
                f"- recommended_next_arc_candidate: {turn_update_review_text(story_completion.get('recommended_next_arc_candidate', ''))}",
            ]
        )
    if candidate_path is not None:
        lines.append(f"- turn_update_candidate: {relative_to_root_text(candidate_path)}")
    if dry_run_path is not None:
        lines.append(f"- apply_turn_dry_run: {relative_to_root_text(dry_run_path)}")
    lines.extend(
        [
            "",
            "## Interpretation",
            "",
            "- The playtest stopped before the next GM Play Mode response.",
            "- Checkpoint artifacts are runner metadata, not Play Mode text.",
            "- No real apply-turn was executed.",
            "- Closure candidates, if present, are review candidates only and do not switch Active Hook automatically.",
            "- Story completion candidates, if present, are checkpoint-only and do not create a story arc automatically.",
            "- Resume quality is not evaluated by this checkpoint alone.",
        ]
    )
    return "\n".join(lines).rstrip() + "\n"


def write_ai_playtest_apply_turn_checkpoint(
    *,
    run_dir: Path,
    session_path: Path,
    transcript_md: Path,
    turn: int,
    tick: dict[str, int | bool],
    history: list[dict[str, str]],
    closure_candidate: Optional[dict[str, object]] = None,
    story_completion: Optional[dict[str, object]] = None,
) -> dict[str, object]:
    prompt_path = run_dir / "checkpoint_turn_update_prompt.md"
    candidate_path = run_dir / "checkpoint_turn_update.md"
    dry_run_path = run_dir / "checkpoint_apply_turn_dry_run.md"
    summary_path = run_dir / "checkpoint_summary.md"

    prompt_path.write_text(
        build_ai_playtest_checkpoint_turn_update_prompt(
            session_path=session_path,
            transcript_md=transcript_md,
            turn=turn,
            tick=tick,
            history=history,
            closure_candidate=closure_candidate,
            story_completion=story_completion,
        ),
        encoding="utf-8",
    )
    candidate_path.write_text(
        build_ai_playtest_checkpoint_turn_update_candidate(
            session_path=session_path,
            transcript_md=transcript_md,
            turn=turn,
            tick=tick,
            closure_candidate=closure_candidate,
            story_completion=story_completion,
        ),
        encoding="utf-8",
    )
    dry_run_result = collect_apply_turn_dry_run_result(session_path, candidate_path)
    dry_run_path.write_text(
        render_apply_turn_dry_run_result(dry_run_result, candidate_path, session_path),
        encoding="utf-8",
    )
    summary_path.write_text(
        render_ai_playtest_checkpoint_summary(
            turn=turn,
            tick=tick,
            checkpoint_mode="dry-run",
            candidate_path=candidate_path,
            dry_run_path=dry_run_path,
            dry_run_result=dry_run_result,
            closure_candidate=closure_candidate,
            story_completion=story_completion,
        ),
        encoding="utf-8",
    )
    return {
        "checkpoint_mode": "dry-run",
        "prompt_path": prompt_path,
        "candidate_path": candidate_path,
        "dry_run_path": dry_run_path,
        "summary_path": summary_path,
        "dry_run_result": dry_run_result,
        "closure_candidate": closure_candidate,
        "story_completion": story_completion,
    }


def append_ai_playtest_checkpoint_record(
    md_path: Path,
    jsonl_path: Path,
    *,
    turn: int,
    artifacts: dict[str, object],
) -> None:
    dry_result = artifacts.get("dry_run_result")
    dry_status = (
        str(dry_result.get("status", "FAIL"))
        if isinstance(dry_result, dict)
        else "not_run"
    )
    record = {
        "turn": turn,
        "role": "apply_turn_checkpoint",
        "timestamp": datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
        "checkpoint_mode": artifacts.get("checkpoint_mode", "off"),
        "apply_turn_executed": False,
        "dry_run_result": dry_status,
        "turn_update_candidate": relative_to_root_text(artifacts["candidate_path"]) if isinstance(artifacts.get("candidate_path"), Path) else "",
        "apply_turn_dry_run": relative_to_root_text(artifacts["dry_run_path"]) if isinstance(artifacts.get("dry_run_path"), Path) else "",
    }
    with jsonl_path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, ensure_ascii=False) + "\n")

    lines = [
        f"## Turn {turn} - APPLY-TURN CHECKPOINT",
        "",
        "Runner metadata only. This is not Play Mode text.",
        "",
        f"- checkpoint_mode: {artifacts.get('checkpoint_mode', 'off')}",
        "- apply_turn_executed: false",
        f"- dry_run_result: {dry_status}",
    ]
    for label, key in [
        ("turn_update_candidate", "candidate_path"),
        ("turn_update_prompt", "prompt_path"),
        ("apply_turn_dry_run", "dry_run_path"),
        ("checkpoint_summary", "summary_path"),
    ]:
        path = artifacts.get(key)
        if isinstance(path, Path):
            lines.append(f"- {label}: {relative_to_root_text(path)}")
    with md_path.open("a", encoding="utf-8") as handle:
        handle.write("\n".join(lines).rstrip() + "\n\n")


def append_checkpoint_summary_to_report(run_dir: Path) -> None:
    summary_path = run_dir / "checkpoint_summary.md"
    if not summary_path.exists():
        return
    report_path = run_dir / "report.md"
    summary_text = summary_path.read_text(encoding="utf-8").strip()
    if report_path.exists():
        existing = report_path.read_text(encoding="utf-8").rstrip()
        if "## Save Checkpoint" in existing:
            return
        body = existing + "\n\n## Save Checkpoint\n\n" + summary_text + "\n"
    else:
        body = "# AI Playtest Report\n\n## Save Checkpoint\n\n" + summary_text + "\n"
    report_path.write_text(body, encoding="utf-8")


def first_closure_candidate(parsed_judge: Optional[dict[str, object]]) -> Optional[dict[str, object]]:
    if not parsed_judge:
        return None
    candidates = parsed_judge.get("closure_candidates")
    if not isinstance(candidates, list) or not candidates:
        return None
    candidate = candidates[0]
    if not isinstance(candidate, dict):
        return None
    if not str(candidate.get("possible_next_question", "") or "").strip():
        return None
    if str(candidate.get("possible_next_hook_type", "") or "") not in {"main", "relationship", "life"}:
        return None
    return candidate


def story_completion_for_checkpoint(
    parsed_judge: Optional[dict[str, object]],
    closure_candidate: Optional[dict[str, object]],
) -> Optional[dict[str, object]]:
    if not parsed_judge or closure_candidate is None:
        return None
    value = parsed_judge.get("story_completion")
    if not isinstance(value, dict):
        return None
    if value.get("story_completion_status") not in {
        "closure_candidate",
        "resolved",
        "deferred",
        "backgrounded",
    }:
        return None
    if value.get("should_apply_now") is not False or value.get("checkpoint_only") is not True:
        return None
    if str(value.get("suggested_active_hook_type", "") or "") not in {"main", "relationship", "life"}:
        return None
    if not str(value.get("recommended_next_arc_candidate", "") or "").strip():
        return None
    return value


def read_ai_playtest_save_checkpoint(path: Path) -> tuple[int, dict[str, int | bool]] | None:
    if not path.exists():
        return None
    text = path.read_text(encoding="utf-8")
    turn_match = re.search(r"^- turn:\s*(\d+)\s*$", text, re.MULTILINE)
    tick_match = re.search(r"^- scene_tick:\s*(\d+)\s*/\s*(\d+)\s*$", text, re.MULTILINE)
    if not turn_match or not tick_match:
        return None
    turn = int(turn_match.group(1))
    display_turn = int(tick_match.group(1))
    interval_turns = int(tick_match.group(2))
    autosave_required = bool(re.search(r"^- autosave_required:\s*true\s*$", text, re.MULTILINE))
    return turn, {
        "display_turn": display_turn,
        "interval_turns": interval_turns,
        "turns_since_save": display_turn,
        "autosave_required": autosave_required,
    }


def update_ai_playtest_checkpoint_with_closure_candidate(
    *,
    run_dir: Path,
    session_path: Path,
    transcript_md: Path,
    closure_candidate: dict[str, object],
    history: list[dict[str, str]],
    story_completion: Optional[dict[str, object]] = None,
) -> Optional[dict[str, object]]:
    checkpoint = read_ai_playtest_save_checkpoint(run_dir / "save_checkpoint.md")
    if checkpoint is None:
        return None
    turn, tick = checkpoint
    return write_ai_playtest_apply_turn_checkpoint(
        run_dir=run_dir,
        session_path=session_path,
        transcript_md=transcript_md,
        turn=turn,
        tick=tick,
        history=history,
        closure_candidate=closure_candidate,
        story_completion=story_completion,
    )


def write_ai_playtest_error(
    path: Path,
    *,
    turn: int,
    role: str,
    error: BaseException,
) -> None:
    body = (
        "# AI Playtest Error\n\n"
        f"- turn: {turn}\n"
        f"- failed_role: {role}\n"
        f"- error_type: {type(error).__name__}\n"
        f"- error: {error}\n"
        f"- timestamp: {datetime.now(timezone.utc).astimezone().isoformat(timespec='seconds')}\n"
    )
    path.write_text(body, encoding="utf-8")


def run_ai_playtest_judge(
    *,
    run_dir: Path,
    transcript_md: Path,
    persona: str,
    turns_completed: int,
    turns_requested: int,
    source_session: str,
    engine: str,
    timeout: float,
    started_at: str,
    verbose: bool,
    quiet: bool,
) -> Optional[dict[str, object]]:
    """Run the AI Judge over a completed run and write report.md / judge_error.md.

    Read-only with respect to saves/ and run_dir/session/. Only writes
    report.md or judge_error.md inside run_dir.
    """

    report_path = run_dir / "report.md"
    error_path = run_dir / "judge_error.md"

    if not quiet:
        print(f"judge: persona={persona} turns={turns_completed} engine={engine} ...", flush=True)

    if turns_completed < 1:
        judged_at = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
        error = JudgeError("no completed turns to judge")
        error_path.write_text(
            render_judge_error_md(
                persona=persona,
                turns_completed=turns_completed,
                turns_requested=turns_requested,
                source_session=source_session,
                engine=engine,
                started_at=started_at,
                judged_at=judged_at,
                error=error,
            ),
            encoding="utf-8",
        )
        if not quiet:
            print(f"judge skipped: {error}")
            print(f"judge error: {error_path.relative_to(ROOT)}")
        return None

    transcript_text = transcript_md.read_text(encoding="utf-8")
    judge_prompt = build_judge_prompt(
        persona=persona,
        turns_completed=turns_completed,
        transcript_md_text=transcript_text,
    )

    raw_response: Optional[str] = None
    try:
        raw_response = run_engine_cli(engine, judge_prompt, timeout=timeout, root=ROOT)
        parsed = parse_judge_response(raw_response)
    except (EngineRunnerError, EngineTimeoutError, JudgeParseError, Exception) as exc:
        judged_at = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
        error_path.write_text(
            render_judge_error_md(
                persona=persona,
                turns_completed=turns_completed,
                turns_requested=turns_requested,
                source_session=source_session,
                engine=engine,
                started_at=started_at,
                judged_at=judged_at,
                error=exc,
                raw_response=raw_response,
            ),
            encoding="utf-8",
        )
        if not quiet:
            print(f"judge failed: {type(exc).__name__}: {exc}")
            print(f"judge error: {error_path.relative_to(ROOT)}")
            print("transcript is preserved.")
        if verbose and raw_response is not None:
            print("--- raw judge response ---")
            print(raw_response)
            print("--- end raw judge response ---", flush=True)
        return None

    judged_at = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    report_md = render_judge_report_md(
        parsed,
        persona=persona,
        turns_completed=turns_completed,
        turns_requested=turns_requested,
        source_session=source_session,
        engine=engine,
        started_at=started_at,
        judged_at=judged_at,
    )
    report_path.write_text(report_md, encoding="utf-8")

    if not quiet:
        print(f"judge result: {parsed['result']}")
        print(f"report: {report_path.relative_to(ROOT)}")
    if verbose:
        print("--- raw judge response ---")
        print(raw_response or "")
        print("--- end raw judge response ---", flush=True)
    return parsed


def run_ai_playtest_segment(
    *,
    run_dir: Path,
    session_path: Path,
    transcript_title: str,
    source_session_label: str,
    run_session_label: str,
    persona: str,
    turns: int,
    requested_engine: str,
    engine: str,
    verbose: bool,
    quiet: bool,
    history: list[dict[str, str]],
    turn_offset: int = 0,
    scene_tick: bool = True,
    apply_turn_checkpoint: bool = False,
) -> tuple[Path, Path, int, str]:
    """Run one playtest segment against an existing session copy.

    ``history`` is mutated in place so growth-smoke can carry conversation
    continuity across segment directories while keeping transcripts separate.
    """

    run_dir.mkdir(parents=True, exist_ok=True)
    transcript_jsonl = run_dir / "transcript.jsonl"
    transcript_md = run_dir / "transcript.md"
    error_path = run_dir / "error.md"

    started_at = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    transcript_md.write_text(
        "\n".join(
            [
                f"# {transcript_title}",
                "",
                f"- source_session: {source_session_label}",
                f"- run_session: {run_session_label}",
                f"- persona: {persona}",
                f"- turns_requested: {turns}",
                f"- engine_requested: {requested_engine}",
                f"- engine_resolved: {engine}",
                f"- scene_tick_enabled: {str(scene_tick).lower()}",
                f"- apply_turn_checkpoint: {str(apply_turn_checkpoint).lower()}",
                f"- history_turns_before_segment: {turn_offset}",
                f"- started_at: {started_at}",
                "",
            ]
        ),
        encoding="utf-8",
    )

    timeout = engine_timeout_seconds()
    completed_turns = 0

    for local_turn in range(1, turns + 1):
        global_turn = turn_offset + local_turn
        if not quiet:
            print(f"turn {local_turn}/{turns} (global {global_turn}): GM ...", flush=True)
        if not history:
            gm_history = []
            player_boundary: Optional[str] = None
        else:
            last_player = history[-1]
            if last_player["role"] == "player":
                player_boundary = format_player_input_boundary(last_player["text"])
                gm_history = history[:-1]
            else:
                player_boundary = None
                gm_history = history

        gm_prompt = build_ai_playtest_gm_prompt(session_path, gm_history, player_boundary)
        try:
            gm_text = run_engine_cli(engine, gm_prompt, timeout=timeout, root=ROOT)
        except (EngineRunnerError, EngineTimeoutError, Exception) as exc:
            write_ai_playtest_error(error_path, turn=local_turn, role="gm", error=exc)
            if not quiet:
                print(f"ai-playtest failed at turn {local_turn} (gm): {exc}")
                print(f"run dir: {run_dir.relative_to(ROOT)}")
                print(f"transcript: {transcript_md.relative_to(ROOT)}")
                print(f"error: {error_path.relative_to(ROOT)}")
            sys.exit(1)

        history.append({"turn": global_turn, "role": "gm", "text": gm_text})
        append_ai_playtest_jsonl(transcript_jsonl, global_turn, "gm", gm_text)
        append_ai_playtest_md(transcript_md, global_turn, "gm", gm_text)
        if verbose:
            print(f"--- GM turn {global_turn} ---")
            print(gm_text)
            print("--- end GM ---", flush=True)

        if scene_tick:
            tick = advance_session_autosave(session_path)
            append_ai_playtest_scene_tick(
                transcript_md,
                transcript_jsonl,
                turn=global_turn,
                tick=tick,
                session_name=session_path.name,
            )
            if not quiet:
                print(
                    f"scene tick: {tick['display_turn']}/{tick['interval_turns']} "
                    f"autosave_required={str(tick['autosave_required']).lower()}",
                    flush=True,
                )
            if tick["autosave_required"]:
                checkpoint_artifacts: Optional[dict[str, object]] = None
                if apply_turn_checkpoint:
                    checkpoint_artifacts = write_ai_playtest_apply_turn_checkpoint(
                        run_dir=run_dir,
                        session_path=session_path,
                        transcript_md=transcript_md,
                        turn=global_turn,
                        tick=tick,
                        history=history,
                    )
                    append_ai_playtest_checkpoint_record(
                        transcript_md,
                        transcript_jsonl,
                        turn=global_turn,
                        artifacts=checkpoint_artifacts,
                    )
                write_ai_playtest_save_checkpoint(
                    run_dir / "save_checkpoint.md",
                    turn=global_turn,
                    tick=tick,
                    session_path=session_path,
                    checkpoint_mode="dry-run" if checkpoint_artifacts else "off",
                    turn_update_candidate=checkpoint_artifacts.get("candidate_path") if checkpoint_artifacts else None,
                    apply_turn_dry_run=checkpoint_artifacts.get("dry_run_path") if checkpoint_artifacts else None,
                    checkpoint_summary=checkpoint_artifacts.get("summary_path") if checkpoint_artifacts else None,
                )
                completed_turns = local_turn
                if not quiet:
                    print(
                        "ai-playtest checkpoint: autosave_required=true; "
                        "stopping before next GM play response.",
                        flush=True,
                    )
                    print(f"checkpoint: {(run_dir / 'save_checkpoint.md').relative_to(ROOT)}")
                    if checkpoint_artifacts:
                        print(
                            "apply-turn checkpoint dry-run: "
                            f"{relative_to_root_text(checkpoint_artifacts['dry_run_path'])}",
                            flush=True,
                        )
                break

        if not quiet:
            print(f"turn {local_turn}/{turns} (global {global_turn}): PLAYER ...", flush=True)
        player_prompt = build_ai_playtest_player_prompt(persona, history[:-1], gm_text)
        try:
            player_text = run_engine_cli(engine, player_prompt, timeout=timeout, root=ROOT)
        except (EngineRunnerError, EngineTimeoutError, Exception) as exc:
            write_ai_playtest_error(error_path, turn=local_turn, role="player", error=exc)
            if not quiet:
                print(f"ai-playtest failed at turn {local_turn} (player): {exc}")
                print(f"run dir: {run_dir.relative_to(ROOT)}")
                print(f"transcript: {transcript_md.relative_to(ROOT)}")
                print(f"error: {error_path.relative_to(ROOT)}")
            sys.exit(1)

        history.append({"turn": global_turn, "role": "player", "text": player_text})
        append_ai_playtest_jsonl(transcript_jsonl, global_turn, "player", player_text)
        append_ai_playtest_md(transcript_md, global_turn, "player", player_text)
        if verbose:
            print(f"--- PLAYER turn {global_turn} ---")
            print(player_text)
            print("--- end PLAYER ---", flush=True)

        completed_turns = local_turn

    return transcript_md, transcript_jsonl, completed_turns, started_at


def run_ai_playtest_session(
    *,
    src_session: Path,
    persona: str,
    turns: int,
    requested_engine: str,
    engine: str,
    verbose: bool,
    quiet: bool,
    judge: bool,
    scene_tick: bool = True,
    apply_turn_checkpoint: bool = False,
) -> Path:
    """Run an AI playtest from start to finish. Returns the run_dir path.

    Used both by ``command_ai_playtest`` and by the dev menu / dev-smoke
    helpers so they can drive the same code path without subprocesses.
    Engine failures still call ``sys.exit(1)`` to preserve the existing
    ai-playtest exit semantics; callers that want to keep going (the menu)
    are expected to catch ``SystemExit``.
    """

    run_dir = ai_playtest_run_dir(persona, src_session.name)
    run_dir.parent.mkdir(parents=True, exist_ok=True)
    if run_dir.exists():
        die(f"run directory already exists: {run_dir}")
    dst_session = run_dir / "session"
    shutil.copytree(src_session, dst_session)

    if not quiet:
        print(f"ai-playtest start: persona={persona} turns={turns} engine={engine} (requested {requested_engine})")
        print(f"source session: {src_session.relative_to(ROOT)}")
        print(f"run dir:        {run_dir.relative_to(ROOT)}")

    history: list[dict[str, str]] = []
    transcript_md, transcript_jsonl, completed_turns, started_at = run_ai_playtest_segment(
        run_dir=run_dir,
        session_path=dst_session,
        transcript_title="AI Playtest Transcript",
        source_session_label=str(src_session.relative_to(ROOT)),
        run_session_label=str(dst_session.relative_to(ROOT)),
        persona=persona,
        turns=turns,
        requested_engine=requested_engine,
        engine=engine,
        verbose=verbose,
        quiet=quiet,
        history=history,
        scene_tick=scene_tick,
        apply_turn_checkpoint=apply_turn_checkpoint,
    )

    if not quiet:
        print(f"ai-playtest complete: {completed_turns}/{turns} turns")
    print(f"run dir:    {run_dir.relative_to(ROOT)}")
    print(f"transcript: {transcript_md.relative_to(ROOT)}")
    print(f"jsonl:      {transcript_jsonl.relative_to(ROOT)}")

    parsed_judge: Optional[dict[str, object]] = None
    if judge:
        parsed_judge = run_ai_playtest_judge(
            run_dir=run_dir,
            transcript_md=transcript_md,
            persona=persona,
            turns_completed=completed_turns,
            turns_requested=turns,
            source_session=str(src_session.relative_to(ROOT)),
            engine=engine,
            timeout=engine_timeout_seconds(),
            started_at=started_at,
            verbose=verbose,
            quiet=quiet,
        )
    closure_candidate = first_closure_candidate(parsed_judge)
    story_completion = story_completion_for_checkpoint(parsed_judge, closure_candidate)
    if apply_turn_checkpoint and closure_candidate is not None:
        update_ai_playtest_checkpoint_with_closure_candidate(
            run_dir=run_dir,
            session_path=dst_session,
            transcript_md=transcript_md,
            closure_candidate=closure_candidate,
            history=history,
            story_completion=story_completion,
        )
    append_checkpoint_summary_to_report(run_dir)

    return run_dir


def command_ai_playtest(args: list[str]) -> None:
    cleaned, persona, turns, requested_engine, verbose, quiet, scene_tick, apply_turn_checkpoint, judge = parse_ai_playtest_options(args)
    if len(cleaned) != 1:
        die("ai-playtest requires <session_name>")
    session_name = cleaned[0]
    src_session = resolve_session(session_name)

    engine = resolve_engine(requested_engine)
    if engine is None:
        die(
            "no AI CLI found for ai-playtest. install codex or claude, "
            f"or pass --engine codex|claude (requested: {requested_engine})."
        )

    run_ai_playtest_session(
        src_session=src_session,
        persona=persona,
        turns=turns,
        requested_engine=requested_engine,
        engine=engine,
        verbose=verbose,
        quiet=quiet,
        judge=judge,
        scene_tick=scene_tick,
        apply_turn_checkpoint=apply_turn_checkpoint,
    )


def growth_run_dir(persona: str, session_name: str) -> Path:
    timestamp = datetime.now(timezone.utc).astimezone().strftime("%Y%m%d_%H%M%S")
    return PLAYTESTS_DIR / "growth_runs" / f"{timestamp}_{persona}_{session_name}"


def parse_growth_smoke_options(
    args: list[str],
) -> tuple[list[str], str, int, int, str, bool, str | None, bool, bool]:
    persona = "normal"
    segments = 3
    turns_per_segment = 10
    engine = "auto"
    judge = True
    judge_engine: str | None = None
    verbose = False
    quiet = False
    judge_seen = False
    no_judge_seen = False
    cleaned: list[str] = []
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--persona":
            index += 1
            if index >= len(args):
                die("--persona requires a value")
            persona = args[index]
        elif arg.startswith("--persona="):
            persona = arg.split("=", 1)[1]
        elif arg == "--segments":
            index += 1
            if index >= len(args):
                die("--segments requires a value")
            try:
                segments = int(args[index])
            except ValueError:
                die("--segments must be a positive integer")
        elif arg.startswith("--segments="):
            try:
                segments = int(arg.split("=", 1)[1])
            except ValueError:
                die("--segments must be a positive integer")
        elif arg == "--turns-per-segment":
            index += 1
            if index >= len(args):
                die("--turns-per-segment requires a value")
            try:
                turns_per_segment = int(args[index])
            except ValueError:
                die("--turns-per-segment must be a positive integer")
        elif arg.startswith("--turns-per-segment="):
            try:
                turns_per_segment = int(arg.split("=", 1)[1])
            except ValueError:
                die("--turns-per-segment must be a positive integer")
        elif arg == "--engine":
            index += 1
            if index >= len(args):
                die("--engine requires codex, claude, or auto")
            engine = args[index]
        elif arg.startswith("--engine="):
            engine = arg.split("=", 1)[1]
        elif arg == "--judge-engine":
            index += 1
            if index >= len(args):
                die("--judge-engine requires codex, claude, or auto")
            judge_engine = args[index]
        elif arg.startswith("--judge-engine="):
            judge_engine = arg.split("=", 1)[1]
        elif arg == "--judge":
            judge_seen = True
            judge = True
        elif arg == "--no-judge":
            no_judge_seen = True
            judge = False
        elif arg == "--verbose":
            verbose = True
        elif arg == "--quiet":
            quiet = True
        else:
            cleaned.append(arg)
        index += 1

    if judge_seen and no_judge_seen:
        die("choose either --judge or --no-judge, not both")
    if persona != "normal":
        die("growth-smoke MVPでは --persona normal のみサポートしています")
    if segments < 1:
        die("--segments must be a positive integer")
    if turns_per_segment < 1:
        die("--turns-per-segment must be a positive integer")
    if engine not in {"auto", "codex", "claude"}:
        die("--engine must be codex, claude, or auto")
    if judge_engine is not None and judge_engine not in {"auto", "codex", "claude"}:
        die("--judge-engine must be codex, claude, or auto")
    if verbose and quiet:
        die("choose either --verbose or --quiet, not both")
    return cleaned, persona, segments, turns_per_segment, engine, judge, judge_engine, verbose, quiet


def _read_report_result(report_path: Path) -> tuple[str, str]:
    if not report_path.exists():
        return "NO_JUDGE", ""
    try:
        text = report_path.read_text(encoding="utf-8")
    except OSError as exc:
        return "WARN", f"report read failed: {exc}"
    result_match = re.search(r"^- Result:\s*(PASS|WARN|FAIL)\s*$", text, re.MULTILINE)
    result = result_match.group(1) if result_match else "WARN"
    summary = ""
    summary_match = re.search(r"## Summary\s*(.*?)(?:\n## |\Z)", text, re.DOTALL)
    if summary_match:
        for line in summary_match.group(1).splitlines():
            stripped = line.strip()
            if stripped and not stripped.startswith("- "):
                summary = " ".join(stripped.split())
                break
    return result, summary[:120]


def render_growth_summary_md(
    *,
    result: str,
    source_session: str,
    run_session: str,
    persona: str,
    engine: str,
    segments: int,
    turns_per_segment: int,
    judge_enabled: bool,
    segment_rows: list[dict[str, str]],
) -> str:
    total_turns = segments * turns_per_segment
    rows = "\n".join(
        f"| {row['segment']} | {row['result']} | {row['notes'] or ''} | {row['report']} |"
        for row in segment_rows
    )
    if not rows:
        rows = "| - | FAIL | no segment completed | - |"

    return (
        "# LILIA Growth Smoke Summary\n\n"
        "## Summary\n"
        f"- Result: {result}\n"
        f"- Source session: {source_session}\n"
        f"- Run session: {run_session}\n"
        f"- Persona: {persona}\n"
        f"- Engine: {engine}\n"
        f"- Segments: {segments}\n"
        f"- Turns per segment: {turns_per_segment}\n"
        f"- Total turns: {total_turns}\n"
        f"- Judge: {'enabled' if judge_enabled else 'disabled'}\n"
        "- Summary mode: aggregate summary, not LLM cross-segment summary.\n\n"
        "## Segment Results\n\n"
        "| Segment | Result | Notes | Report |\n"
        "|---|---|---|---|\n"
        f"{rows}\n\n"
        "## Growth Observations\n\n"
        "- 関係が進んだ兆候: Human review required. 各segment transcript/reportを横断して確認する。\n"
