def dump_character_yaml(data: dict) -> str:
    try:
        import yaml

        return yaml.safe_dump(data, allow_unicode=True, sort_keys=False)
    except ModuleNotFoundError:
        def scalar(value: object) -> str:
            if value is None:
                return ""
            text = str(value).replace('"', '\\"')
            return f'"{text}"'

        lines: list[str] = []
        for key in ["name", "age", "occupation"]:
            if key in data and data[key] is not None:
                lines.append(f"{key}: {scalar(data[key])}")
        appearance = data.get("appearance")
        if isinstance(appearance, dict):
            lines.append("appearance:")
            for key in ["hair_style", "hair_color", "notes"]:
                lines.append(f"  {key}: {scalar(appearance.get(key))}")
        tone = data.get("tone")
        if isinstance(tone, dict):
            lines.append("tone:")
            lines.append(f"  rule: {scalar(tone.get('rule'))}")
            lines.append("  examples:")
            examples = tone.get("examples") if isinstance(tone.get("examples"), list) else []
            for example in examples:
                if isinstance(example, dict):
                    lines.append(f"    - user: {scalar(example.get('user'))}")
                    lines.append(f"      char: {scalar(example.get('char'))}")
        personality = data.get("personality")
        if isinstance(personality, list):
            lines.append("personality:")
            for item in personality:
                lines.append(f"  - {scalar(item)}")
        reactions = data.get("reactions")
        if isinstance(reactions, dict):
            lines.append("reactions:")
            for key, value in reactions.items():
                lines.append(f"  {key}: {scalar(value)}")
        forbidden = data.get("forbidden")
        if isinstance(forbidden, list):
            lines.append("forbidden:")
            for item in forbidden:
                lines.append(f"  - {scalar(item)}")
        context = data.get("context")
        if isinstance(context, dict):
            lines.append("context:")
            for key in ["backstory", "current_situation"]:
                lines.append(f"  {key}: {scalar(context.get(key))}")
        return "\n".join(lines) + "\n"


def result_value(result: object, key: str, default: object = None) -> object:
    if isinstance(result, dict):
        return result.get(key, default)
    return getattr(result, key, default)


def profile_sections_count(profile: str) -> int:
    return len(re.findall(r"^##\s+", profile, re.MULTILINE))


def render_documents_from_character_yaml(
    character: object,
    answers: dict[int | str, str],
    engine: str,
) -> tuple[dict[str, str], dict[str, object]]:
    if not hasattr(character, "model_dump"):
        raise TypeError("character object must provide model_dump()")
    character_data = character.model_dump(exclude_none=True)
    profile, profile_meta = generate_profile_from_character_data(answers, character_data, engine)
    documents = {
        "lilia/main/character.yaml": dump_character_yaml(character_data),
        "lilia/main/profile.md": profile,
    }
    return documents, profile_meta


def generate_profile_from_character_data(
    answers: dict[int | str, str],
    character_data: dict[str, object],
    engine: str,
) -> tuple[str, dict[str, object]]:
    try:
        from tools.character.profile_generator import ProfileGenerationError, generate_profile_document
    except Exception as exc:  # pragma: no cover - depends on local environment
        raise RuntimeError(f"failed to import AI profile generator: {exc}") from exc

    try:
        profile_result = generate_profile_document(
            answers=answers,
            character_yaml=character_data,
            engine=engine,
        )
    except ProfileGenerationError:
        raise

    profile = str(result_value(profile_result, "profile_md", "") or "")
    if not profile.strip():
        raise RuntimeError("AI profile generator returned an empty profile_md")

    validation_pass = result_value(profile_result, "validation_pass", True)
    if validation_pass is False:
        raise RuntimeError("AI profile generator returned validation_pass=false without ProfileGenerationError")

    profile_name = clean_lilia_name(str(character_data.get("name") or "")) or extract_profile_name(profile)
    if profile_name:
        profile = replace_profile_name(profile, profile_name)
    profile_meta = {
        "engine": result_value(profile_result, "engine_used", engine),
        "validation_pass": validation_pass,
        "retry_count": result_value(
            profile_result,
            "validation_retry_count",
            result_value(profile_result, "retry_count", 0),
        ),
        "sections_count": result_value(profile_result, "sections_count", profile_sections_count(profile)),
    }
    return profile, profile_meta


def load_character_yaml_document(text: str) -> dict[str, object]:
    try:
        import yaml

        parsed = yaml.safe_load(text)
    except ModuleNotFoundError:
        from tools.character.core.simple_schema import load_simple_character_yaml

        temp_path: Optional[Path] = None
        try:
            with tempfile.NamedTemporaryFile("w", encoding="utf-8", suffix=".yaml", delete=False) as temp_file:
                temp_file.write(text)
                temp_path = Path(temp_file.name)
            character = load_simple_character_yaml(temp_path)
            parsed = character.model_dump(exclude_none=True) if hasattr(character, "model_dump") else character
        finally:
            if temp_path and temp_path.exists():
                temp_path.unlink()
    if not isinstance(parsed, dict):
        raise RuntimeError("character.yaml did not contain a mapping")
    return parsed


def load_character_sheet_document(text: str) -> object:
    raw = load_character_yaml_document(text)
    try:
        from tools.character.core.master import CharacterSheet

        return CharacterSheet.from_dict(raw)
    except Exception as exc:
        raise RuntimeError(f"character.yaml schema invalid: {exc}") from exc


def generate_character_yaml_data(
    answers: dict[int | str, str],
    requested_engine: str,
) -> tuple[dict[str, object], str, str]:
    instruction = build_character_instruction_from_answers(answers)
    try:
        from tools.character.core.master import generate_character

        character = generate_character(instruction, engine=requested_engine)
        character_data = character.model_dump(exclude_none=True)
    except Exception as exc:
        raise RuntimeError(f"character YAML generation failed: {exc}") from exc
    engine_label = resolve_engine(requested_engine) or requested_engine
    return character_data, engine_label, f"generated via {engine_label}"


def generate_character_documents(
    answers: dict[int | str, str],
    requested_engine: str,
) -> tuple[dict[str, str], Optional[str], str, Optional[dict[str, object]], dict[str, object]]:
    engine = resolve_engine(requested_engine)
    if engine is None:
        return {}, None, f"{requested_engine} engine unavailable", None, {}

    instruction = build_character_instruction_from_answers(answers)
    try:
        from tools.character.core.master import generate_character

        character = generate_character(instruction, engine=engine)
        character_data = character.model_dump(exclude_none=True)
        profile_engine = requested_engine if requested_engine == "auto" else engine
        documents, profile_meta = render_documents_from_character_yaml(character, answers, profile_engine)
        return documents, engine, f"generated via {engine}", character_data, profile_meta
    except Exception as exc:
        if exc.__class__.__name__ == "ProfileGenerationError":
            raise
        return {}, None, f"{engine} CLI failed: {exc}", None, {}


def command_apply_newgame(args: list[str]) -> None:
    args, requested_engine, force = parse_apply_newgame_options(args)
    if len(args) != 2:
        die("apply-newgame requires <session_name> <answers.md> [--engine codex|claude|auto] [--force]")

    session_path = resolve_session(args[0])
    logger = OperationLogger("apply_newgame", session_path.name)
    globals()["_CURRENT_OPERATION_LOGGER"] = logger
    logger.section("apply-newgame START")
    logger.write(
        "start_context",
        session_id=session_path.name,
        timestamp=datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
        force=force,
    )
    answers_path = Path(args[1]).expanduser()
    logger.write("inputs", answers_path=answers_path, requested_engine=requested_engine)
    answers = parse_newgame_answers(answers_path)
    data = read_session_json(session_path)
    phase = str(data.get("apply_newgame_phase") or "pending")
    if force:
        remove_apply_newgame_outputs(session_path)
        data["apply_newgame_phase"] = "pending"
        write_session_json(session_path, data)
        phase = "pending"
        logger.write("force_reset", removed_files=APPLY_NEWGAME_GENERATED_FILES)
    if phase in {"documents_generated", "complete"}:
        die("apply-newgame は既に完了しています。やり直す場合は `--force` を指定してください")
    if phase not in {"pending", "character_yaml_generated", "profile_generated", "spines_generated"}:
        phase = "pending"
        update_apply_newgame_phase(session_path, phase)

    logger.section("Q&A")
    question_count = 9 if is_wave101_answers(answers) else (6 if is_wave10_answers(answers) else 8)
    for number in range(1, question_count + 1):
        logger.write("answer", question=f"Q{number}", value=answer(answers, number).replace("\n", " / "))

    logger.section("LLM Calls")
    documents: dict[str, str] = {}
    profile_meta: dict[str, object] = {}
    selected_engine = resolve_engine(requested_engine) or requested_engine

    if phase == "pending":
        try:
            character_data, selected_engine, generation_status = generate_character_yaml_data(answers, requested_engine)
        except Exception as exc:
            logger.write("[character_yaml] failed", error=str(exc))
            print(f"Error: character.yaml 生成に失敗しました: {exc}", file=sys.stderr)
            sys.exit(1)
        documents["lilia/main/character.yaml"] = dump_character_yaml(character_data)
        write_session_file(session_path, "lilia/main/character.yaml", documents["lilia/main/character.yaml"])
        update_apply_newgame_phase(session_path, "character_yaml_generated")
        phase = "character_yaml_generated"
        logger.write("[character_yaml] generated via", engine=selected_engine, status=generation_status)
    else:
        documents["lilia/main/character.yaml"] = read_required_session_file(session_path, "lilia/main/character.yaml")
        try:
            character = load_character_sheet_document(documents["lilia/main/character.yaml"])
            character_data = character.model_dump(exclude_none=True)
        except Exception as exc:
            logger.write("[character_yaml] checkpoint_invalid", error=str(exc))
            print(f"Error: character.yaml の読み込みに失敗しました: {exc}", file=sys.stderr)
            sys.exit(1)
        logger.write("[character_yaml] resumed", phase=phase)

    if phase == "character_yaml_generated":
        try:
            profile, profile_meta = generate_profile_from_character_data(answers, character_data, requested_engine)
            documents["lilia/main/profile.md"] = profile
        except Exception as exc:
            if exc.__class__.__name__ == "ProfileGenerationError":
                if exception_caused_by(exc, EngineTimeoutError):
                    logger.write(
                        "[profile] llm_timeout",
                        engine=requested_engine,
                        timeout=engine_timeout_seconds(),
                        error=str(exc),
                    )
                logger.write("[profile] validation", status="failed", error=str(exc))
                print(f"Error: profile.md 生成に失敗しました: {exc}", file=sys.stderr)
                sys.exit(1)
            raise
        write_session_file(session_path, "lilia/main/profile.md", documents["lilia/main/profile.md"])
        update_apply_newgame_phase(session_path, "profile_generated")
        phase = "profile_generated"
        logger.write("[profile] generated via", engine=profile_meta.get("engine", selected_engine))
        logger.write(
            "[profile] validation",
            status="pass" if profile_meta.get("validation_pass", True) else "failed",
            retry_count=profile_meta.get("retry_count", 0),
            sections_count=profile_meta.get("sections_count", 0),
        )
    else:
        documents["lilia/main/profile.md"] = read_required_session_file(session_path, "lilia/main/profile.md")
        logger.write("[profile] resumed", phase=phase)

    logger.section("Profile Validation")
    try:
        from tools.character.profile_validator import validate_profile_output

        profile_valid, profile_errors = validate_profile_output(
            documents.get("lilia/main/profile.md", ""),
            answers,
            character_data or {},
        )
    except Exception as exc:
        profile_valid = False
        profile_errors = [f"profile validator failed: {exc}"]
    if not profile_valid:
        logger.write("[profile] validation", status="failed", error="; ".join(profile_errors[:5]))
        print(f"Error: profile.md 生成に失敗しました: {'; '.join(profile_errors[:5])}", file=sys.stderr)
        sys.exit(1)

    profile_name = extract_profile_name(documents["lilia/main/profile.md"])
    if not profile_name:
        profile_name, name_source = resolve_lilia_name_layers(
            profile=documents["lilia/main/profile.md"],
            answers=answers,
            logger=logger,
        )
        logger.write("name_resolution", source=name_source, placeholder=profile_name == PLACEHOLDER_LILIA_NAME)
        documents["lilia/main/profile.md"] = replace_profile_name(
            documents["lilia/main/profile.md"],
            profile_name,
        )
        write_session_file(session_path, "lilia/main/profile.md", documents["lilia/main/profile.md"])
    else:
        logger.write("name_resolution", source="layer_a_profile", placeholder=False)

    logger.section("Story Spine")
    if phase == "profile_generated":
        try:
            from tools.story.spine_generator import SpineGenerationError, generate_story_and_relationship_spine

            spine_result = generate_story_and_relationship_spine(
                answers=answers,
                character_yaml=character_data,
                engine=requested_engine,
            )
            documents["current/story_spine.md"] = spine_result["story_spine_md"]
            documents["story/relationship_spine.md"] = spine_result["relationship_spine_md"]
            write_session_file(session_path, "current/story_spine.md", documents["current/story_spine.md"])
            write_session_file(session_path, "story/relationship_spine.md", documents["story/relationship_spine.md"])
            update_apply_newgame_phase(session_path, "spines_generated")
            phase = "spines_generated"
            logger.write("[story_spine] generated via", engine=spine_result.get("engine_used", requested_engine))
            logger.write("[story_spine] selected_structure", name=spine_result.get("selected_structure", ""))
            logger.write("[story_spine] selected_pattern", ids=spine_result.get("selected_pattern", []))
            logger.write("[story_spine] selection_reason", reason=spine_result.get("selection_reason", ""))
            logger.write(
                "[story_spine] validation",
                status="pass",
                retry_count=spine_result.get("validation_retry_count", 0),
            )
        except SpineGenerationError as exc:
            logger.write("[story_spine] validation", status="failed", error=str(exc))
            print(f"Error: ストーリー生成に失敗しました: {exc}", file=sys.stderr)
            sys.exit(1)
    else:
        documents["current/story_spine.md"] = read_required_session_file(session_path, "current/story_spine.md")
        documents["story/relationship_spine.md"] = read_required_session_file(session_path, "story/relationship_spine.md")
        logger.write("[story_spine] resumed", phase=phase)

    logger.section("Session Documents")
    downstream_result: dict[str, object] = {}
    if phase == "spines_generated":
        try:
            logger.write(
                "[downstream_docs] wrapper enter",
                engine=requested_engine,
                lilia_name=profile_name,
                session_name=session_path.name,
                profile_chars=len(documents["lilia/main/profile.md"]),
                story_spine_chars=len(documents["current/story_spine.md"]),
                relationship_spine_chars=len(documents["story/relationship_spine.md"]),
            )
            downstream_result = generate_downstream_session_documents(
                answers=answers,
                profile_md=documents["lilia/main/profile.md"],
                character_yaml=character_data,
                story_spine_md=documents["current/story_spine.md"],
                relationship_spine_md=documents["story/relationship_spine.md"],
                lilia_name=profile_name,
                engine=requested_engine,
                session_name=session_path.name,
            )
        except Exception as exc:
            logger.write("[downstream_docs] failed", error=str(exc))
            print(f"Error: 下流ファイル生成に失敗しました: {exc}", file=sys.stderr)
            sys.exit(1)

        downstream_documents = downstream_result["documents"]
        downstream_documents["current/knowledge_state.md"] = render_ai_knowledge_state_document(
            ai_knowledge_state_md=downstream_documents["current/knowledge_state.md"],
            protagonist_md=downstream_documents["current/protagonist.md"],
            profile=documents["lilia/main/profile.md"],
            answers=answers,
            lilia_name=profile_name,
            story_fields=story_fields_from_story_spine_markdown(documents["current/story_spine.md"]),
        )
        for rel_path, content in downstream_documents.items():
            write_session_file(session_path, rel_path, content)
        style_documents = render_style_documents(answers)
        for rel_path, content in style_documents.items():
            write_session_file(session_path, rel_path, content)
        update_apply_newgame_phase(session_path, "documents_generated")
        phase = "documents_generated"
    else:
        downstream_documents = {
            rel_path: read_required_session_file(session_path, rel_path)
            for rel_path in DOWNSTREAM_SESSION_DOCUMENT_FILES
        }
        style_documents = {
            "style/reference.md": read_required_session_file(session_path, "style/reference.md"),
            "style/rules.md": read_required_session_file(session_path, "style/rules.md"),
        }
        logger.write("[downstream_docs] resumed", phase=phase)

    try:
        from tools.session.document_validator import validate_session_documents

        docs_valid, docs_errors = validate_session_documents(
            downstream_documents,
            answers,
            story_spine_md=documents["current/story_spine.md"],
        )
    except Exception as exc:
        docs_valid = False
        docs_errors = [f"downstream validator failed: {exc}"]
    if not docs_valid:
        logger.write("[downstream_docs] validation", status="failed", error="; ".join(docs_errors[:8]))
        for rel_path in DOWNSTREAM_SESSION_DOCUMENT_FILES:
            path = session_path / rel_path
            if path.exists():
                path.unlink()
        update_apply_newgame_phase(session_path, "spines_generated")
        print(f"Error: 下流ファイル生成に失敗しました: {'; '.join(docs_errors[:8])}", file=sys.stderr)
        sys.exit(1)

    groups = downstream_result.get("groups", {}) if isinstance(downstream_result, dict) else {}
    for group_name, label in [
        ("group_a", "scene/event_card/hotset/relationship_overview/story_deck"),
        ("group_b", "lilia/main/*"),
        ("group_c", "protagonist/knowledge_state"),
    ]:
        group_meta = groups.get(group_name, {}) if isinstance(groups, dict) else {}
        logger.write(
            f"[downstream_docs] {group_name} ({label}) generated via",
            engine=group_meta.get("engine_used", downstream_result.get("engine_used", requested_engine)),
        )
        logger.write(
            f"[downstream_docs] {group_name} validation",
            status="pass",
            retry_count=group_meta.get("validation_retry_count", 0),
        )
    documents.update(downstream_documents)
    documents.update(style_documents)
    logger.write(
        "[downstream_docs] generated",
        engine=downstream_result.get("engine_used", requested_engine) if isinstance(downstream_result, dict) else requested_engine,
        retry_count=downstream_result.get("validation_retry_count", 0) if isinstance(downstream_result, dict) else 0,
        count=len(downstream_documents),
        files=list(downstream_documents),
    )

    logger.section("Generated Files")
    logger.write("generated_files", files=list(documents))

    data = read_session_json(session_path)
    data["mode"] = data.get("mode") or "new"
    data["current_phase"] = "first_scene_ready"
    data["apply_newgame_phase"] = "complete"
    data["active_lilia"] = data.get("active_lilia") or "main"
    ensure_lilia_names(data, profile_name)
    initialization = data.setdefault("initialization", {})
    initialization["qa_completed"] = True
    initialization["light_story_reference_pass"] = "minimal_applied"
    initialization["first_scene_status"] = "ready"
    ensure_autosave(data)
    write_session_json(session_path, data)
    logger.write(
        "write_complete",
        updated_files=["session.json", *documents.keys()],
        downstream_validation="pass",
    )
    logger.section("apply-newgame END")
    logger.write("end", status="success")

    print(f"session: {session_path.relative_to(ROOT)}")
    engine_note = "auto-selected" if requested_engine == "auto" else "requested"
    print(f"engine: {selected_engine} ({engine_note})")
    print("character.yaml: generated or resumed from checkpoint")
    print("profile.md: generated by AI from character.yaml")
    print(f"session documents: generated via tools.session.document_generator ({len(DOWNSTREAM_SESSION_DOCUMENT_FILES)} files)")
    print(f"applied: {answers_path}")
    print("phase: first_scene_ready")
    print("updated:")
    print("  session.json")
    for rel_path in documents:
        print(f"  {rel_path}")
    print(f"log: {logger.path.relative_to(ROOT)}")


def command_apply_turn(args: list[str]) -> None:
    dry_run = False
    if "--dry-run" in args:
        dry_run = True
        args = [arg for arg in args if arg != "--dry-run"]
    force = False
    if "--force" in args:
        force = True
        args = [arg for arg in args if arg != "--force"]
    if len(args) != 2:
        die("apply-turn requires [--dry-run] [--force] <session_name> <turn_update.md>")

    session_path = resolve_session(args[0])
    logger = OperationLogger("apply_turn", session_path.name)
    logger.section("apply-turn START")
    logger.write(
        "start_context",
        session_id=session_path.name,
        timestamp=datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
        dry_run=dry_run,
        force=force,
    )
    update_path = Path(args[1]).expanduser()
    sections = parse_turn_update(update_path)
    if not sections:
        die("turn_update.md has no non-empty supported sections")
    fingerprint = turn_update_fingerprint(sections)
    update_source = turn_update_source_label(update_path)
    session_data = read_session_json(session_path)
    duplicate = find_applied_turn_update(session_data, fingerprint)
    logger.write(
        "inputs",
        update_path=update_path,
        dry_run=dry_run,
        force=force,
        sections=list(sections),
        turn_update_sha256=fingerprint,
    )
    if duplicate is not None:
        message = duplicate_turn_update_message(duplicate, fingerprint)
        duplicate_action = "force" if force else "warn" if dry_run else "blocked"
        logger.write("duplicate_check", status="duplicate", action=duplicate_action)
        if dry_run:
            print(f"warning: {message}", file=sys.stderr)
        elif force:
            print(f"warning: {message}", file=sys.stderr)
        else:
            die(message)
    else:
        logger.write("duplicate_check", status="new")
    logger.section("References")
    logger.write(
        "read",
        files=[
            "prompt/core.md",
            "current/profile.md",
            "current/story_spine.md",
            "current/knowledge_state.md (if present)",
            str(update_path),
        ],
    )
    logger.section("LLM Call")
    logger.write("turn generation", status="not_performed_apply_turn_merges_turn_update_only")

    timestamp = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    updated: list[str] = []
    skipped: list[str] = []

    def mark_updated(rel_path: str) -> None:
        if rel_path not in updated:
            updated.append(rel_path)

    def mark_skipped(message: str) -> None:
        if message not in skipped:
            skipped.append(message)

    for key, body in sections.items():
        if key == "hook_updates":
            for rel_path in apply_hook_updates(session_path, body, timestamp, dry_run):
                mark_updated(rel_path)
            continue

        if key == "next_hook":
            event_card_path = "current/event_card.md"
            story_deck_path = "story/story_deck.md"
            promoted_paths = [
                rel_path
                for rel_path, section_key in [
                    ("current/scene.md", "scene"),
                    ("current/event_card.md", "event_card"),
                    ("current/hotset.md", "hotset"),
                ]
                if section_key not in sections
            ]
            if not dry_run:
                append_session_file(session_path, story_deck_path, render_next_hook_block(timestamp, body, "Candidate Next Hook"))
                if promoted_paths:
                    for rel_path in promote_next_hook_to_active_state(
                        session_path,
                        body,
                        timestamp,
                        update_scene="scene" not in sections,
                        update_event_card="event_card" not in sections,
                        update_hotset="hotset" not in sections,
                    ):
                        mark_updated(rel_path)
                else:
                    append_session_file(session_path, event_card_path, render_next_hook_block(timestamp, body, "Next Hook"))
                    mark_updated(event_card_path)
            else:
                for rel_path in promoted_paths:
                    mark_updated(rel_path)
                if not promoted_paths:
                    mark_updated(event_card_path)
            mark_updated(event_card_path)
            mark_updated(story_deck_path)
            continue

        rel_path = TURN_UPDATE_TARGETS[key]
        if key == "knowledge_state":
            target = session_path / rel_path
            if not target.exists():
                mark_skipped(f"{rel_path} missing; skipped knowledge_state merge for legacy session")
                continue
            merged = merge_knowledge_state_content(target.read_text(encoding="utf-8"), body)
            if not dry_run:
                write_session_file(session_path, rel_path, merged)
        elif key == "hotset":
            if not dry_run:
                write_session_file(session_path, rel_path, render_hotset_update(timestamp, body))
        else:
            if not dry_run:
                append_session_file(session_path, rel_path, render_turn_update_block(timestamp, body))
        mark_updated(rel_path)

    if not dry_run:
        autosave = ensure_autosave(session_data)
        autosave["turns_since_save"] = 0
        autosave["autosave_required"] = False
        mark_first_scene_started_if_needed(session_data)
        remember_applied_turn_update(session_data, fingerprint, sections, update_source, timestamp)
        write_session_json(session_path, session_data)
        mark_updated("session.json")
    logger.section("Updates")
    logger.write("write_complete", dry_run=dry_run, updated=updated, skipped=skipped)
    if not dry_run:
        print_voice_continuity_report(session_path)
    logger.section("apply-turn END")
    logger.write("end", status="dry_run" if dry_run else "success")

    print(f"{'dry-run: ' if dry_run else ''}applied: {update_path}")
    print(f"session: {session_path.relative_to(ROOT)}")
    print(f"timestamp: {timestamp}")
    print("would update:" if dry_run else "updated:")
    for rel_path in updated:
        print(f"  {rel_path}")
    if skipped:
        print("skipped:")
        for message in skipped:
            print(f"  {message}")
    print(f"log: {logger.path.relative_to(ROOT)}")


def advance_session_autosave(session_path: Path) -> dict[str, int | bool]:
    data = read_session_json(session_path)
    autosave = ensure_autosave(data)

    try:
        interval = int(autosave.get("interval_turns", AUTOSAVE_DEFAULTS["interval_turns"]))
    except (TypeError, ValueError):
        interval = AUTOSAVE_DEFAULTS["interval_turns"]
    if interval < 1:
        interval = AUTOSAVE_DEFAULTS["interval_turns"]
    autosave["interval_turns"] = interval

    try:
        turns_since_save = int(autosave.get("turns_since_save", 0))
    except (TypeError, ValueError):
        turns_since_save = 0
    if turns_since_save < 0:
        turns_since_save = 0

    turns_since_save += 1
    autosave["turns_since_save"] = turns_since_save

    enabled = bool(autosave.get("enabled", True))
    autosave["enabled"] = enabled
    autosave["autosave_required"] = enabled and turns_since_save >= interval
    write_session_json(session_path, data)

    display_turn = min(turns_since_save, interval)
    return {
        "display_turn": display_turn,
        "interval_turns": interval,
        "turns_since_save": turns_since_save,
        "autosave_required": bool(autosave["autosave_required"]),
    }


def render_scene_tick_save_required_message(session_name: str, interval: int) -> str:
    return (
        "SAVE REQUIRED: GM must enter save mode now. "
        "Write turn_update.md with only changed sections from the last "
        f"{interval} turns, then run "
        f"./lilia apply-turn {session_name} <turn_update.md>. "
        "Do not return the next play response until save completes."
    )


def command_scene_tick(args: list[str]) -> None:
    if len(args) != 1:
        die("scene-tick requires <session_name>")

    session_path = resolve_session(args[0])
    tick = advance_session_autosave(session_path)

    print(f"scene tick: {tick['display_turn']}/{tick['interval_turns']}")
    print(f"autosave_required: {str(tick['autosave_required']).lower()}")
    if tick["autosave_required"]:
        print(
            render_scene_tick_save_required_message(
                session_path.name,
                int(tick["interval_turns"]),
            )
        )


