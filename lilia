def render_history_block(history: list[dict[str, str]]) -> str:
    if not history:
        return "（履歴なし。これがresume後の最初の1ターン目です。）"
    blocks: list[str] = []
    for entry in history:
        label = "GM" if entry["role"] == "gm" else "PLAYER"
        blocks.append(f"### {label} (turn {entry['turn']})\n{entry['text'].rstrip()}")
    return "\n\n".join(blocks)


