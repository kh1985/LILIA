def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    sys.exit(code)


def parse_run_options(args: list[str]) -> tuple[list[str], bool, bool, str]:
    prompt_only = False
    run = False
    engine = "auto"
    cleaned: list[str] = []
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--prompt-only":
            prompt_only = True
        elif arg == "--run":
            run = True
        elif arg == "--engine":
            index += 1
            if index >= len(args):
                die("--engine requires codex, claude, or auto")
            engine = args[index]
        elif arg.startswith("--engine="):
            engine = arg.split("=", 1)[1]
        else:
            cleaned.append(arg)
        index += 1

    if prompt_only and run:
        die("choose either --prompt-only or --run, not both")
    if engine not in {"auto", "codex", "claude"}:
        die("--engine must be codex, claude, or auto")
    return cleaned, prompt_only, run, engine


def validate_session_name(name: str) -> str:
    if not SESSION_NAME_RE.match(name):
        die("session name may contain only letters, numbers, underscore, dot, and hyphen")
    return name


def next_session_name() -> str:
    SAVES_DIR.mkdir(exist_ok=True)
    index = 1
    while True:
        name = f"session_{index:03d}"
        if not (SAVES_DIR / name).exists():
            return name
        index += 1


def session_dir(name: str) -> Path:
    return SAVES_DIR / validate_session_name(name)


def read_session_json(path: Path) -> dict:
    json_path = path / "session.json"
    if not json_path.exists():
        return {}
    try:
        return json.loads(json_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}


def write_session_json(path: Path, data: dict) -> None:
    (path / "session.json").write_text(
        json.dumps(data, ensure_ascii=False, indent=2) + "\n",
        encoding="utf-8",
    )


def ensure_autosave(data: dict) -> dict:
    autosave = data.get("autosave")
    if not isinstance(autosave, dict):
        autosave = {}
        data["autosave"] = autosave
    for key, value in AUTOSAVE_DEFAULTS.items():
        autosave.setdefault(key, value)
    return autosave


def is_placeholder_lilia_name(value: object) -> bool:
    if not isinstance(value, str):
        return True
    compact = re.sub(r"\s+", "", value).strip("「」『』'\"")
    if not compact:
        return True
    lowered = compact.lower()
    return (
        lowered in {"lilia", "リリア", "未設定", "未定", "なし", "特になし"}
        or lowered.startswith("lilia（仮")
        or lowered.startswith("lilia(仮")
        or lowered.startswith("リリア（仮")
        or lowered.startswith("リリア(仮")
    )


def clean_lilia_name(value: object) -> str:
    if not isinstance(value, str):
        return ""
    name = value.strip().strip("「」『』'\"")
    name = re.split(r"\s+#", name, maxsplit=1)[0].strip()
    return "" if is_placeholder_lilia_name(name) else name


def extract_profile_name(profile: str) -> str:
    for line in profile.splitlines():
        match = re.match(r"^name:\s*(.+?)\s*$", line)
        if match:
            return clean_lilia_name(match.group(1))
    return ""


def explicit_name_from_answers(answers: dict[int, str]) -> str:
    patterns = [
        r"(?:名前|個体名|name)\s*(?:は|:|：|=)\s*[「『]?([A-Za-z一-龥ぁ-んァ-ヶー]{1,12})(?=」|』|で|に|と|、|。|\s|$)",
        r"[「『]?([A-Za-z一-龥ぁ-んァ-ヶー]{1,12})[」』]?\s*(?:という|っていう)?\s*名前",
    ]
    for text in answers.values():
        for pattern in patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                name = clean_lilia_name(match.group(1))
                if name:
                    return name
    return ""


def generated_lilia_name(answers: dict[int, str], session_name: str = "") -> str:
    explicit = explicit_name_from_answers(answers)
    if explicit:
        return explicit
    seed = session_name + "\n" + "\n".join(answers.get(number, "") for number in range(1, 8))
    index = sum(ord(char) for char in seed) % len(FALLBACK_LILIA_NAMES)
    return FALLBACK_LILIA_NAMES[index]


def ensure_lilia_names(data: dict, name: str = "") -> str:
    resolved = clean_lilia_name(name)
    if not resolved:
        resolved = clean_lilia_name(data.get("lilia_name"))
    if not resolved:
        resolved = clean_lilia_name(data.get("lilia_display_name"))
    data["lilia_name"] = resolved
    data["lilia_display_name"] = resolved
    return resolved


def replace_profile_name(profile: str, name: str) -> str:
    if re.search(r"^name:\s*.+$", profile, flags=re.MULTILINE):
        return re.sub(r"^name:\s*.+$", f"name: {name}", profile, count=1, flags=re.MULTILINE)
    return profile.replace("## 基礎情報\n", f"## 基礎情報\nname: {name}\n", 1)


def write_session_file(session_path: Path, rel_path: str, content: str) -> None:
    target = session_path / rel_path
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(content.rstrip() + "\n", encoding="utf-8")


def append_session_file(session_path: Path, rel_path: str, content: str) -> None:
    target = session_path / rel_path
    target.parent.mkdir(parents=True, exist_ok=True)
    existing = target.read_text(encoding="utf-8") if target.exists() else ""
    separator = "\n\n" if existing.strip() else ""
    target.write_text(existing.rstrip() + separator + content.rstrip() + "\n", encoding="utf-8")


def bullet_block(text: str) -> str:
    stripped = text.strip()
    if not stripped:
        return "- 未回答"
    return "\n".join(f"- {line}" if line.strip() else "" for line in stripped.splitlines())


def parse_newgame_answers(path: Path) -> dict[int, str]:
    if not path.exists():
        die(f"answers file not found: {path}")
    content = path.read_text(encoding="utf-8")
    sections: dict[int, list[str]] = {}
    current: Optional[int] = None
    for line in content.splitlines():
        match = re.match(r"^##\s*Q([1-7])(?:\b|[.\s:：-])", line.strip(), re.IGNORECASE)
        if match:
            current = int(match.group(1))
            sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)

    answers = {number: "\n".join(lines).strip() for number, lines in sections.items()}
    missing = [f"Q{number}" for number in range(1, 8) if not answers.get(number)]
    if missing:
        die(f"answers.md is missing non-empty sections: {', '.join(missing)}")
    return answers


def normalize_turn_update_heading(heading: str) -> str:
    return re.sub(r"[\s-]+", "_", heading.strip().lower())


def parse_turn_update(path: Path) -> dict[str, str]:
    if not path.exists():
        die(f"turn update file not found: {path}")

    sections: dict[str, list[str]] = {}
    current: Optional[str] = None
    for line in path.read_text(encoding="utf-8").splitlines():
        match = re.match(r"^##\s+(.+?)\s*$", line)
        if match:
            key = normalize_turn_update_heading(match.group(1))
            current = key if key in TURN_UPDATE_TARGETS else None
            if current is not None:
                sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)

    return {
        key: "\n".join(lines).strip()
        for key, lines in sections.items()
        if "\n".join(lines).strip()
    }


def answer(answers: dict[int, str], number: int) -> str:
