def supplementary_question(number: int, text: str) -> str:
    clean = text.strip()
    if is_omakase_literal(clean) or compact_text(clean) in {"特になし", "なし"}:
        return ""
    if number == 1:
        missing = q1_missing_fields(clean)
        if missing:
            return f"{'、'.join(missing)}も教えてください。または、それぞれ『おまかせ』でも OK です。"
        personality = q1_components(clean).get("personality", "")
        if compact_text(personality) in {compact_text(word) for word in ABSTRACT_PERSONALITY_WORDS}:
            return f"「{personality}」をもう少し具体的に教えてもらえますか？ 誰にどう出る性格か、行動で1つだけ足してください。"
    elif number == 2:
        parts = [part for part in re.split(r"[、,/／。]+", clean) if part.strip()]
        if len(parts) <= 1 and not is_omakase_literal(clean):
            return "見た目をもう少しだけ具体化できますか？ 髪、目、体型、服装のうち1つでも OK です。"
        if compact_text(clean) in {compact_text(word) for word in ABSTRACT_VISUAL_WORDS}:
            return f"「{clean}」を、髪・目・体型・服装のどれか1つに置き換えて教えてください。"
    elif number == 3:
        if not clean:
            return "物的な印を1つ教えてください。または『おまかせ』でも OK です。"
        if compact_text(clean) in {"アクセサリー", "持ち物", "小物", "癖", "香り", "音"}:
            return "その印をもう少し具体化できますか？ 物、癖、香り、音のどれか1つを具体名で足してください。"
    elif number == 4:
        if not clean:
            return "他人に見せる顔と、一人の時の違いを教えてください。または『おまかせ』でも OK です。"
        outward, inward, _ = split_gap_answer(clean)
        if not (outward and inward):
            return "表に見せる顔と、内側または一人の時の違いを両方教えてください。不足分は『おまかせ』でも OK です。"
        if compact_text(clean) in {"表裏ない", "普通", "特にない"}:
            return "差が小さい場合でも、外から見える態度と一人の時の出方を1つずつ教えてください。"
    elif number == 5:
        if not clean:
            return "内面に持っているものを1つ教えてください。傷、癖、こだわり、職業的な特徴でも OK です。または『おまかせ』でも OK です。"
        if compact_text(clean) in {"いろいろあった", "過去がある", "事情がある"}:
            return "それが何として残っているかを、もう少しだけ具体化できますか？ 出来事、癖、こだわり、特徴のどれでも OK です。"
    elif number == 6:
        if not clean:
            return "関係性と最初の場面を教えてください。または『おまかせ』でも OK です。"
        has_relation = any(word in clean for word in ["初対面", "顔見知り", "知人", "同じ", "幼馴染", "友人", "先輩", "後輩", "元々"])
        has_scene = any(word in clean for word in ["で", "に", "ところ", "場", "中", "途中", "会", "再会", "拾", "話"])
        if not (has_relation and has_scene):
            return "関係性と、どこでどんなふうに始まるかを両方教えてください。または不足分は『おまかせ』でも OK です。"
        if compact_text(clean) in {compact_text(word) for word in ABSTRACT_SCENE_WORDS}:
            return "最初の場面をもう少し具体化できますか？ 時間帯、場所の性質、何が起きるかのうち1つで OK です。"
    elif number == 8:
        missing = protagonist_missing_fields(clean)
        if missing:
            return f"{'、'.join(missing)}も教えてください。または、不足分は『おまかせ』でも OK です。"
        if compact_text(clean) in {"普通", "無難"}:
            return "身体感覚、服装、仕事のどれか1つだけ具体化してください。"
    elif number == 7 and not clean:
        return "呼ばれ方を教えてください。または『おまかせ』でも OK です。"
    return ""


