        f"- autosave_required: {str(tick['autosave_required']).lower()}",
    ]
    if tick["autosave_required"]:
        lines.extend(
            [
                "- checkpoint: Save Mode required before the next GM play response.",
                "- apply_turn_executed: false",
                "- instruction: inspect the transcript, write a fresh `turn_update.md`, "
                "and apply it only from an explicit checkpoint workflow. "
                "The AI Playtest runner does not run `apply-turn` automatically.",
            ]
        )
    with md_path.open("a", encoding="utf-8") as handle:
        handle.write("\n".join(lines).rstrip() + "\n\n")


def write_ai_playtest_save_checkpoint(
    path: Path,
    *,
    turn: int,
    tick: dict[str, int | bool],
    session_path: Path,
    checkpoint_mode: str = "off",
    turn_update_candidate: Optional[Path] = None,
    apply_turn_dry_run: Optional[Path] = None,
    checkpoint_summary: Optional[Path] = None,
) -> None:
    extra_lines = [
        f"- checkpoint_mode: {checkpoint_mode}",
    ]
    if turn_update_candidate is not None:
        extra_lines.append(f"- turn_update_candidate: {relative_to_root_text(turn_update_candidate)}")
    if apply_turn_dry_run is not None:
        extra_lines.append(f"- apply_turn_dry_run: {relative_to_root_text(apply_turn_dry_run)}")
    if checkpoint_summary is not None:
        extra_lines.append(f"- checkpoint_summary: {relative_to_root_text(checkpoint_summary)}")
    body = (
        "# AI Playtest Save Checkpoint\n\n"
        "AI Playtest stopped before the next GM play response because "
        "`autosave_required: true` was reached.\n\n"
        f"- turn: {turn}\n"
        f"- session: {relative_to_root_text(session_path)}\n"
        f"- scene_tick: {tick['display_turn']}/{tick['interval_turns']}\n"
        f"- turns_since_save: {tick['turns_since_save']}\n"
        f"- autosave_required: {str(tick['autosave_required']).lower()}\n"
        "- apply_turn_executed: false\n"
        + "\n".join(extra_lines)
        + "\n\n"
        "Next step: inspect the transcript, write a fresh `turn_update.md`, then apply it only from "
        "an explicit checkpoint workflow against a disposable smoke session or a future path-aware "
        "playtest apply-turn command. Do not reuse stale turn_update content.\n"
    )
    path.write_text(body, encoding="utf-8")


def relative_to_root_text(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)


