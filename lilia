def _overall_growth_result(segment_rows: list[dict[str, str]], judge_enabled: bool) -> str:
    if not segment_rows:
        return "FAIL"
    if any(row["result"] == "FAIL" for row in segment_rows):
        return "FAIL"
    if any(row["result"] in {"WARN", "NO_JUDGE"} for row in segment_rows):
        return "WARN" if judge_enabled else "PASS"
    return "PASS"


def run_growth_smoke(
    *,
    src_session: Path,
    persona: str,
    segments: int,
    turns_per_segment: int,
    requested_engine: str,
    engine: str,
    judge: bool,
    requested_judge_engine: str,
    judge_engine: str,
    verbose: bool,
    quiet: bool,
) -> Path:
    run_dir = growth_run_dir(persona, src_session.name)
    run_dir.parent.mkdir(parents=True, exist_ok=True)
    if run_dir.exists():
        die(f"growth run directory already exists: {run_dir}")
    dst_session = run_dir / "session"
    shutil.copytree(src_session, dst_session)

    if not quiet:
        print(
            f"growth-smoke start: persona={persona} segments={segments} "
            f"turns_per_segment={turns_per_segment} engine={engine} "
            f"judge={'on' if judge else 'off'}"
        )
        print(f"source session: {src_session.relative_to(ROOT)}")
        print(f"run dir:        {run_dir.relative_to(ROOT)}")

    global_history: list[dict[str, str]] = []
    segment_rows: list[dict[str, str]] = []
    growth_error_path = run_dir / "growth_error.md"

    try:
        for segment_index in range(1, segments + 1):
            segment_name = f"segment_{segment_index:03d}"
            segment_dir = run_dir / segment_name
            if not quiet:
                print()
                print(f"=== {segment_name}: {turns_per_segment} turns ===")
            history_before = len([entry for entry in global_history if entry["role"] == "gm"])
            transcript_md, _, completed_turns, started_at = run_ai_playtest_segment(
                run_dir=segment_dir,
                session_path=dst_session,
                transcript_title=f"LILIA Growth Smoke Transcript {segment_index:03d}",
                source_session_label=str(src_session.relative_to(ROOT)),
                run_session_label=str(dst_session.relative_to(ROOT)),
                persona=persona,
                turns=turns_per_segment,
                requested_engine=requested_engine,
                engine=engine,
                verbose=verbose,
                quiet=quiet,
                history=global_history,
                turn_offset=history_before,
            )
            row = {
                "segment": f"{segment_index:03d}",
                "result": "NO_JUDGE",
                "notes": "",
                "report": "",
            }
            if judge:
                run_ai_playtest_judge(
                    run_dir=segment_dir,
                    transcript_md=transcript_md,
                    persona=persona,
                    turns_completed=completed_turns,
                    turns_requested=turns_per_segment,
                    source_session=str(src_session.relative_to(ROOT)),
                    engine=judge_engine,
                    timeout=engine_timeout_seconds(),
                    started_at=started_at,
                    verbose=verbose,
                    quiet=quiet,
                )
                report_path = segment_dir / "report.md"
                error_path = segment_dir / "judge_error.md"
                if report_path.exists():
                    result, notes = _read_report_result(report_path)
                    row["result"] = result
                    row["notes"] = notes
                    row["report"] = f"{segment_name}/report.md"
                elif error_path.exists():
                    row["result"] = "WARN"
                    row["notes"] = "judge failed; see judge_error.md"
                    row["report"] = f"{segment_name}/judge_error.md"
            else:
                row["report"] = "-"
            segment_rows.append(row)
    except BaseException as exc:
        growth_error_path.write_text(
            "# LILIA Growth Smoke Error\n\n"
            f"- error_type: {type(exc).__name__}\n"
            f"- error: {exc}\n"
            f"- timestamp: {datetime.now(timezone.utc).astimezone().isoformat(timespec='seconds')}\n"
            "- transcript files already written are preserved.\n",
            encoding="utf-8",
        )
        raise
    finally:
        result = _overall_growth_result(segment_rows, judge)
        (run_dir / "growth_summary.md").write_text(
            render_growth_summary_md(
                result=result,
                source_session=str(src_session.relative_to(ROOT)),
                run_session=str(dst_session.relative_to(ROOT)),
                persona=persona,
                engine=engine,
                segments=segments,
                turns_per_segment=turns_per_segment,
                judge_enabled=judge,
                segment_rows=segment_rows,
            ),
            encoding="utf-8",
        )

    if not quiet:
        print()
        print("growth-smoke complete")
    print(f"run dir:        {run_dir.relative_to(ROOT)}")
    print(f"growth summary: {(run_dir / 'growth_summary.md').relative_to(ROOT)}")
    return run_dir


def command_growth_smoke(args: list[str]) -> None:
    (
        cleaned,
        persona,
        segments,
        turns_per_segment,
        requested_engine,
        judge,
        requested_judge_engine,
        verbose,
        quiet,
    ) = parse_growth_smoke_options(args)
    if len(cleaned) != 1:
        die("growth-smoke requires <session_name>")
    src_session = resolve_session(cleaned[0])
    engine = resolve_engine(requested_engine)
    if engine is None:
        die(
            "no AI CLI found for growth-smoke. install codex or claude, "
            f"or pass --engine codex|claude (requested: {requested_engine})."
        )
    requested_judge_engine_final = requested_judge_engine or requested_engine
    judge_engine = engine
    if judge:
        resolved_judge = resolve_engine(requested_judge_engine_final)
        if resolved_judge is None:
            die(
                "no AI CLI found for growth-smoke judge. install codex or claude, "
                f"or pass --judge-engine codex|claude (requested: {requested_judge_engine_final})."
            )
        judge_engine = resolved_judge
    run_growth_smoke(
        src_session=src_session,
        persona=persona,
        segments=segments,
        turns_per_segment=turns_per_segment,
        requested_engine=requested_engine,
        engine=engine,
        judge=judge,
        requested_judge_engine=requested_judge_engine_final,
        judge_engine=judge_engine,
        verbose=verbose,
        quiet=quiet,
    )


