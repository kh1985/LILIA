def answer_or_default(answers: dict[int | str, str], number: int, default: str) -> str:
    value = answer(answers, number).replace("\n", " / ").strip()
    if not value:
        return default
    if is_non_specific_literal(value):
        return default
    return value


def infer_protagonist_body_fields(body_style: str) -> tuple[str, str, str, str]:
    compact = re.sub(r"\s+", "", body_style)
    sex = "未確定"
    if "女" in compact:
        sex = "女"
    elif "男" in compact:
        sex = "男"

    height = "未確定"
    cm_match = re.search(r"(\d{2,3}\s*cm)", body_style, re.IGNORECASE)
    if cm_match:
        height = cm_match.group(1).replace(" ", "")
    elif any(word in compact for word in ["高め", "高い", "長身"]):
        height = "高め"
    elif any(word in compact for word in ["低め", "低い", "小柄", "背が低"]):
        height = "低め"
    elif any(word in compact for word in ["中くらい", "中肉中背", "中背"]):
        height = "中くらい"

    build = "未確定"
    if "細身" in compact:
        build = "細身"
    elif any(word in compact for word in ["がっしり", "筋肉質"]):
        build = "がっしり"
    elif any(word in compact for word in ["普通", "中肉中背", "中肉"]):
        build = "普通"

    clothes = body_style if body_style else "未確定"
    return sex, height, build, clothes


