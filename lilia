def infer_fallback_descriptive_constraint(appearance: str) -> str:
    clean = re.sub(r"\s+", " ", appearance).strip()
    if not clean or clean == UNCONFIRMED:
        return UNCONFIRMED
    parts = [part.strip() for part in re.split(r"[、。/／\n,;；]+", clean) if part.strip()]
    for part in parts:
        if any(word in part for word in DESCRIPTIVE_FALLBACK_KEYWORDS):
            return part[:60]
    return (parts[0] if parts else clean)[:60]


