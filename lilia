def profile_sections(profile: str) -> dict[str, str]:
    sections: dict[str, list[str]] = {}
    current: Optional[str] = None
    for line in profile.splitlines():
        match = re.match(r"^##\s+(.+?)\s*$", line)
        if match:
            heading = match.group(1).strip()
            current = "context" if heading.startswith("context ") else heading
            sections.setdefault(current, [])
            continue
        if current is not None:
            sections[current].append(line)
    return {key: "\n".join(lines).strip() for key, lines in sections.items()}


def profile_clean_line(line: str) -> str:
    return re.sub(r"^[-*]\s*", "", line.strip()).strip()


def profile_unlabeled_value(line: str) -> str:
    if ":" not in line:
        return line
    label, value = line.split(":", 1)
    if label.strip() in {"まだ言わないこと", "すぐには開示しない理由"}:
        return value.strip()
    return line


def profile_line_value(line: str) -> str:
    return line.split(":", 1)[1].strip() if ":" in line else line.strip()


def profile_phrase(text: str) -> str:
    phrase = re.sub(r"[。.!！?？]+$", "", text.strip())
    phrase = re.sub(r"(がある|が残っている|が見える)$", "", phrase).strip()
    return phrase


def profile_short_items(text: str, limit: int = 3) -> str:
    phrase = profile_phrase(text)
    parts = [part.strip() for part in re.split(r"[、,/]+", phrase) if part.strip()]
    if not parts:
        return phrase
    return "、".join(parts[:limit])


def profile_place_focus(text: str) -> str:
